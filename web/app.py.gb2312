@app.post("/api/wechat/login")

async def wechat_login(login_method: str = Form(...), username: str = Depends(get_current_username)):

    """澶勭悊寰俊鐧诲綍璇锋眰"""

    try:

        if login_method == "qrcode":

            # 鍘熸湁鐨勬壂鐮佺櫥褰曢€昏緫

            if not MODULES_LOADED:

                return {"success": False, "message": "妯″潡鏈姞杞斤紝鏃犳硶鐧诲綍"}

            

            # 瀵煎叆WechatAPI

            import WechatAPI

            

            # 鍒涘缓WechatAPI瀹㈡埛锟?

            api_config = config.get("WechatAPIServer", {})

            client = WechatAPI.WechatAPIClient("127.0.0.1", api_config.get("port", 9000))

            

            # 鑾峰彇璁惧淇℃伅

            robot_stat_path = PROJECT_ROOT / "resource" / "robot_stat.json"

            if os.path.exists(robot_stat_path):

                with open(robot_stat_path, "r") as f:

                    robot_stat = json.load(f)

                

                device_name = robot_stat.get("device_name", None)

                device_id = robot_stat.get("device_id", None)

                wxid = robot_stat.get("wxid", None)

            else:

                device_name = None

                device_id = None

                wxid = None

            

            if not device_name:

                device_name = client.create_device_name()

            if not device_id:

                device_id = client.create_device_id()

            

            # 鑾峰彇浜岀淮锟?

            uuid, url = await client.get_qr_code(device_id=device_id, device_name=device_name, print_qr=True)

            

            return {

                "success": True, 

                "method": "qrcode", 

                "uuid": uuid, 

                "url": url,

                "device_id": device_id,

                "device_name": device_name

            }

        

        elif login_method == "awaken":

            # 鍞ら啋鐧诲綍閫昏緫

            logger.info("寮€濮嬪鐞嗗敜閱掔櫥褰曡锟?)

            

            # 鍏堝皾璇曟帶鍒舵満鍣ㄤ汉鍚姩(濡傛灉鏈繍锟?

            robot_running = is_robot_running()

            logger.info(f"鏈哄櫒浜鸿繍琛岀姸锟? {'杩愯锟? if robot_running else '鏈繍锟?}")

            

            if not robot_running:

                logger.info("鏈哄櫒浜烘湭杩愯锛屽皾璇曞惎锟?)

                control_robot("start")

                # 绛夊緟鏈哄櫒浜哄惎锟?

                start_success = False

                for i in range(15):  # 澧炲姞绛夊緟鏃堕棿锟?5锟?

                    logger.info(f"绛夊緟鏈哄櫒浜哄惎锟?..绗瑊i+1}娆℃锟?)

                    if is_robot_running():

                        start_success = True

                        logger.info("鏈哄櫒浜哄凡鎴愬姛鍚姩")

                        break

                    await asyncio.sleep(1)

                

                if not start_success:

                    logger.warning("鏈哄櫒浜哄惎鍔ㄨ秴锟?)

            

            # 浠庢棩蹇椾腑鑾峰彇浜岀淮鐮乁RL

            logger.info("灏濊瘯浠庢棩蹇椾腑鑾峰彇浜岀淮鐮乁RL")

            qrcode_url = get_qrcode_from_logs()

            

            if qrcode_url:

                logger.info(f"鎴愬姛浠庢棩蹇椾腑鑾峰彇鍒颁簩缁寸爜URL: {qrcode_url[:30]}...")

                # 濡傛灉鎵惧埌浜岀淮鐮乁RL锛屼娇鐢ㄤ笌鎵爜鐧诲綍鐩稿悓鐨勬柟寮忚繑锟?

                login_uuid = str(uuid.uuid4())

                return {

                    "success": True,

                    "method": "qrcode",

                    "url": qrcode_url,

                    "uuid": login_uuid,

                    "device_id": None,

                    "message": "宸蹭粠鏃ュ織涓壘鍒版渶鏂扮殑鐧诲綍浜岀淮锟?

                }

            else:

                logger.warning("鏈粠鏃ュ織涓壘鍒颁簩缁寸爜URL锛屽皾璇曞敜閱掑凡鐧诲綍鐨勮处锟?)

                # 濡傛灉娌℃壘鍒颁簩缁寸爜URL锛屼娇鐢ㄥ師鏉ョ殑鍞ら啋鐧诲綍閫昏緫

                if not MODULES_LOADED:

                    logger.error("妯″潡鏈姞杞斤紝鏃犳硶缁х画鍞ら啋鐧诲綍")

                    return {"success": False, "message": "妯″潡鏈姞杞斤紝鏃犳硶鐧诲綍"}

                

                try:

                    # 瀵煎叆WechatAPI

                    import WechatAPI

                    

                    # 鍒涘缓WechatAPI瀹㈡埛锟?

                    api_config = config.get("WechatAPIServer", {})

                    client = WechatAPI.WechatAPIClient("127.0.0.1", api_config.get("port", 9000))

                    

                    # 鑾峰彇璁惧淇℃伅

                    robot_stat_path = PROJECT_ROOT / "resource" / "robot_stat.json"

                    if os.path.exists(robot_stat_path):

                        logger.info(f"璇诲彇鏈哄櫒浜虹姸鎬佹枃锟? {robot_stat_path}")

                        try:

                            with open(robot_stat_path, "r") as f:

                                robot_stat = json.load(f)

                            

                            device_name = robot_stat.get("device_name", None)

                            device_id = robot_stat.get("device_id", None)

                            wxid = robot_stat.get("wxid", None)

                            

                            logger.info(f"鏈哄櫒浜虹姸鎬佷俊锟? device_name={device_name}, device_id={device_id}, wxid={wxid}")

                        except Exception as e:

                            logger.error(f"璇诲彇鏈哄櫒浜虹姸鎬佹枃浠跺け锟? {e}")

                            device_name = None

                            device_id = None

                            wxid = None

                    else:

                        logger.warning(f"鏈哄櫒浜虹姸鎬佹枃浠朵笉瀛樺湪: {robot_stat_path}")

                        device_name = None

                        device_id = None

                        wxid = None

                    

                    if not wxid:

                        logger.error("鏃犳硶鎵惧埌wxid淇℃伅锛屾棤娉曞敜閱掔櫥锟?)

                        login_uuid = str(uuid.uuid4())

                        return {

                            "success": False, 

                            "message": "鏃犳硶鍞ら啋鐧诲綍锛屾湭鎵惧埌wxid淇℃伅",

                            "uuid": login_uuid,

                            "need_manual": True  # 鍛婅瘔鍓嶇鍙兘闇€瑕佹墜鍔ㄨ緭鍏RL

                        }

                    

                    # 灏濊瘯鍞ら啋鐧诲綍

                    logger.info(f"灏濊瘯鍞ら啋鐧诲綍锛寃xid={wxid}")

                    cached_info = await client.get_cached_info(wxid)

                    if cached_info:

                        logger.info(f"鎵惧埌璐﹀彿缂撳瓨淇℃伅: {cached_info}")

                        uuid = await client.awaken_login(wxid)

                        logger.info(f"鍞ら啋鐧诲綍鎴愬姛锛寀uid={uuid}")

                        return {"success": True, "method": "awaken", "uuid": uuid}

                    else:

                        logger.warning(f"鏈壘鍒拌处锟?{wxid} 鐨勭紦瀛樹俊锟?)

                        login_uuid = str(uuid.uuid4())

                        return {

                            "success": False, 

                            "message": "鏃犳硶鍞ら啋鐧诲綍锛岃处鍙风紦瀛樹笉瀛樺湪",

                            "uuid": login_uuid,

                            "need_manual": True  # 鍛婅瘔鍓嶇鍙兘闇€瑕佹墜鍔ㄨ緭鍏RL

                        }

                except Exception as e:

                    logger.error(f"鍞ら啋鐧诲綍杩囩▼涓嚭鐜板紓锟? {e}")

                    logger.error(traceback.format_exc())

                    login_uuid = str(uuid.uuid4())

                    return {

                        "success": False, 

                        "message": f"鍞ら啋鐧诲綍澶辫触: {str(e)}",

                        "uuid": login_uuid,

                        "need_manual": True  # 鍛婅瘔鍓嶇鍙兘闇€瑕佹墜鍔ㄨ緭鍏RL

                    }

        

        return {"success": False, "message": "涓嶆敮鎸佺殑鐧诲綍鏂瑰紡"}

    except Exception as e:

        logger.error(f"鐧诲綍璇锋眰寮傚父: {e}")

        logger.error(traceback.format_exc())

        return {"success": False, "message": f"鐧诲綍璇锋眰澶辫触: {str(e)}"}



@app.get("/api/wechat/check_login/{uuid}")

async def check_login_status(uuid: str, device_id: Optional[str] = None, username: str = Depends(get_current_username)):

    try:

        if not MODULES_LOADED:

            return {"success": False, "message": "妯″潡鏈姞杞斤紝鏃犳硶妫€鏌ョ櫥褰曠姸锟?}

        

        # 瀵煎叆WechatAPI

        import WechatAPI

        

        # 鍒涘缓WechatAPI瀹㈡埛锟?

        api_config = config.get("WechatAPIServer", {})

        client = WechatAPI.WechatAPIClient("127.0.0.1", api_config.get("port", 9000))

        

        # 妫€鏌ョ櫥褰曠姸锟?

        status, data = await client.check_login_uuid(uuid, device_id=device_id)

        

        if status:

            # 鑾峰彇鐧诲綍璐﹀彿淇℃伅

            client.wxid = data.get("acctSectResp").get("userName")

            client.nickname = data.get("acctSectResp").get("nickName")

            client.alias = data.get("acctSectResp").get("alias")

            client.phone = data.get("acctSectResp").get("bindMobile")

            

            # 淇濆瓨鐧诲綍淇℃伅

            robot_stat_path = PROJECT_ROOT / "resource" / "robot_stat.json"

            robot_stat = {

                "wxid": client.wxid,

                "device_name": device_id,  # 杩欓噷鍙兘鏈夐棶棰橈紝搴旇鏄痙evice_name

                "device_id": device_id

            }

            

            with open(robot_stat_path, "w") as f:

                json.dump(robot_stat, f)

            

            # 淇濆瓨涓汉淇℃伅

            profile_path = PROJECT_ROOT / "resource" / "profile.json"

            profile = {

                "wxid": client.wxid,

                "nickname": client.nickname,

                "alias": client.alias,

                "phone": client.phone

            }

            

            with open(profile_path, "w") as f:

                json.dump(profile, f)

            

            return {

                "success": True, 

                "logged_in": True,

                "wxid": client.wxid,

                "nickname": client.nickname,

                "alias": client.alias

            }

        else:

            return {"success": True, "logged_in": False, "message": data}

            

    except Exception as e:

        return {"success": False, "message": f"妫€鏌ョ櫥褰曠姸鎬佸け锟? {str(e)}"}



@app.post("/api/settings/save")

async def save_settings(config_data: Dict[str, Any] = FastAPIBody(...), username: str = Depends(get_current_username)):

    try:

        # 璇诲彇鐜版湁閰嶇疆

        current_config = load_toml_config(config_path)

        if not current_config:

            return {"success": False, "message": "璇诲彇閰嶇疆鏂囦欢澶辫触"}

        

        # 鏇存柊閰嶇疆

        for section, settings in config_data.items():

            if isinstance(settings, dict):

                # 澶勭悊宓屽閰嶇疆閮ㄥ垎

                if section not in current_config:

                    current_config[section] = {}

                

                for key, value in settings.items():

                    current_config[section][key] = value

            else:

                # 澶勭悊椤剁骇閰嶇疆锟?

                current_config[section] = settings

        

        # 淇濆瓨閰嶇疆

        if save_toml_config(config_path, current_config):

            return {"success": True, "message": "璁剧疆宸蹭繚锟?}

        else:

            return {"success": False, "message": "淇濆瓨閰嶇疆鏂囦欢澶辫触"}

    except Exception as e:

        logger.error(f"淇濆瓨璁剧疆澶辫触: {e}")

        logger.error(traceback.format_exc())

        return {"success": False, "message": f"淇濆瓨璁剧疆澶辫触: {str(e)}"}



@app.get("/api/logs")

async def get_logs_api(limit: int = 10, search: str = None, level: str = None, username: str = Depends(get_current_username)):

    """鑾峰彇鏈€杩戠殑鏃ュ織鎺ュ彛"""

    try:

        # 纭繚鏃ュ織鐩綍瀛樺湪

        logs_dir = Path(PROJECT_ROOT) / "logs"

        if not logs_dir.exists():

            logs_dir.mkdir(exist_ok=True)

            logger.info(f"鍒涘缓鏃ュ織鐩綍: {logs_dir}")

            # 鍒涘缓涓€涓垵濮嬫棩蹇楁枃浠讹紝浠ヤ究鍓嶇鍙互鐪嬪埌涓€浜涘唴锟?

            with open(logs_dir / "XYBot_init.log", "w", encoding="utf-8") as f:

                f.write(f"{datetime.now().strftime('%Y-%m-%d %H:%M:%S')} | INFO | 鍒濆鍖栨棩蹇楁枃浠禱n")

                f.write(f"{datetime.now().strftime('%Y-%m-%d %H:%M:%S')} | INFO | 鑾峰彇鍒扮櫥褰曚簩缁寸爜: http://weixin.qq.com/x/oudYJBEvV_gnGKNpZ5gF\n")

        

        # 妫€鏌ユ棩蹇楁枃浠舵暟閲忥紝濡傛灉瓒呰繃20涓紝鍒欎繚鐣欐渶鏂扮殑10锟?

        try:

            manage_log_files(logs_dir)

        except Exception as e:

            logger.warning(f"绠＄悊鏃ュ織鏂囦欢鏃跺嚭锟? {e}")

            

        logs = get_recent_logs(limit)

        

        # 鏍规嵁鎼滅储鏉′欢杩囨护鏃ュ織

        if search or level:

            logs = filter_logs(logs, search, level)

            

        logger.info(f"API鑾峰彇锟?{len(logs)} 鏉℃棩锟?)

        return {"success": True, "logs": logs}

    except Exception as e:

        logger.error(f"鑾峰彇鏃ュ織澶辫触: {e}")

        logger.error(traceback.format_exc())

        return {"success": False, "message": f"鑾峰彇鏃ュ織澶辫触: {str(e)}"}



@app.get("/api/logs/download")

async def download_logs_api(username: str = Depends(get_current_username)):

    """涓嬭浇鏃ュ織鏂囦欢"""

    try:

        logs_dir = PROJECT_ROOT / "logs"

        if not logs_dir.exists():

            logs_dir.mkdir(parents=True, exist_ok=True)

            

        # 鎵惧嚭鏈€鏂扮殑鏃ュ織鏂囦欢

        log_files = list(logs_dir.glob("*.log"))

        if not log_files:

            return JSONResponse(content={"success": False, "message": "鏈壘鍒版棩蹇楁枃锟?}, status_code=404)

            

        latest_log = max(log_files, key=lambda f: f.stat().st_mtime)

        

        # 杩斿洖鏂囦欢

        return FileResponse(

            path=latest_log, 

            filename=f"XBotV2_{datetime.now().strftime('%Y%m%d_%H%M%S')}.log",

            media_type="text/plain"

        )

    except Exception as e:

        logger.error(f"涓嬭浇鏃ュ織鏃跺嚭锟? {e}")

        return JSONResponse(content={"success": False, "message": f"涓嬭浇鏃ュ織澶辫触: {str(e)}"}, status_code=500)



@app.get("/api/events")

async def get_events_api(limit: int = 10, username: str = Depends(get_current_username)):

    """鑾峰彇绯荤粺浜嬩欢"""

    try:

        # 杩欓噷鍙互浠庢暟鎹簱鑾峰彇绯荤粺浜嬩欢锛岀洰鍓嶄娇鐢ㄦ棩蹇楁ā锟?

        logs = get_recent_logs(limit=limit)

        events = []

        

        # 杩囨护鍑洪噸瑕佷簨锟?

        for log in filter_logs(logs, None, None):

            # 妫€鏌ユ槸鍚︽槸閲嶈鏃ュ織

            if "鐧诲綍" in (log.get("content") or log.get("message") or ""):

                log["event_type"] = "login"

            elif "鍚姩" in (log.get("content") or log.get("message") or ""):

                log["event_type"] = "start"

            elif "閿欒" in (log.get("content") or log.get("message") or "") or log.get("level") == "ERROR":

                log["event_type"] = "error"

            else:

                log["event_type"] = "info"

                

            events.append(log)

            

        return {"success": True, "events": events}

    except Exception as e:

        logger.error(f"鑾峰彇绯荤粺浜嬩欢鏃跺嚭锟? {e}")

        return {"success": False, "message": f"鑾峰彇绯荤粺浜嬩欢澶辫触: {str(e)}"}



def filter_logs(logs, search=None, level=None):

    """鏍规嵁鎼滅储鏉′欢杩囨护鏃ュ織"""

    if not logs:

        return []

        

    filtered_logs = logs

    

    # 鎸夋棩蹇楃骇鍒繃锟?

    if level and level.lower() != 'all':

        filtered_logs = [

            log for log in filtered_logs 

            if log and (log.get("level", "").upper() == level.upper() or 

                       (isinstance(log, str) and level.upper() in log.upper()))

        ]

    

    # 鎸夊叧閿瘝鎼滅储

    if search:

        search_lower = search.lower()

        filtered_logs = []

        for log in logs:

            # 澶勭悊瀵硅薄鏍煎紡鏃ュ織

            if isinstance(log, dict):

                content = log.get("content", "") or log.get("message", "")

                if isinstance(content, str) and search_lower in content.lower():

                    filtered_logs.append(log)

            # 澶勭悊瀛楃涓叉牸寮忔棩锟?

            elif isinstance(log, str) and search_lower in log.lower():

                filtered_logs.append(log)

    

    # 纭繚鎵€鏈夋棩蹇楀璞￠兘鏈塩ontent瀛楁

    for log in filtered_logs:

        if isinstance(log, dict) and ("content" not in log or log["content"] is None):

            # 灏濊瘯浠巑essage瀛楁鑾峰彇鍐呭

            if "message" in log and log["message"] is not None:

                log["content"] = log["message"]

            else:

                # 璁剧疆榛樿鍐呭

                log["content"] = "(鏃犲唴锟?"

    

    return filtered_logs



def manage_log_files(logs_dir, max_files=20, keep_files=10):

    """绠＄悊鏃ュ織鏂囦欢鏁伴噺锛岄槻姝㈢鐩樼┖闂磋€楀敖"""

    try:

        log_files = list(logs_dir.glob("*.log"))

        if len(log_files) > max_files:

            # 鎸変慨鏀规椂闂存帓锟?

            log_files.sort(key=lambda x: x.stat().st_mtime)

            # 鍒犻櫎杈冩棫鐨勬枃浠讹紝淇濈暀鏈€鏂扮殑keep_files锟?

            for old_file in log_files[:-keep_files]:

                try:

                    old_file.unlink()

                    logger.info(f"宸插垹闄ゆ棫鏃ュ織鏂囦欢: {old_file}")

                except Exception as e:

                    logger.warning(f"鍒犻櫎鏃ф棩蹇楁枃浠舵椂鍑洪敊: {e}")

    except Exception as e:

        logger.error(f"绠＄悊鏃ュ織鏂囦欢鏃跺嚭锟? {e}")

        raise



@app.get("/api/plugin_marketplace")

async def get_plugin_marketplace_api(

    category: str = None, 

    query: str = None, 

    limit: int = 50, 

    offset: int = 0, 

    sort_by: str = "updated_at", 

    sort_order: str = "desc",

    username: str = Depends(get_current_username)

):

    """鑾峰彇鎻掍欢甯傚満涓殑鎻掍欢鍒楄〃"""

    try:

        # 鑾峰彇鎻掍欢浠撳簱瀹炰緥

        repo = get_plugin_repository()

        

        # 鑾峰彇鎻掍欢鍒楄〃

        plugins, total = repo.get_plugins(

            category=category, 

            query=query, 

            limit=limit, 

            offset=offset, 

            sort_by=sort_by, 

            sort_order=sort_order

        )

        

        return {

            "success": True, 

            "plugins": plugins, 

            "total": total,

            "page": offset // limit + 1,

            "total_pages": (total + limit - 1) // limit

        }

    except Exception as e:

        logger.error(f"鑾峰彇鎻掍欢甯傚満鏁版嵁澶辫触: {e}")

        logger.error(traceback.format_exc())

        return {"success": False, "message": f"鑾峰彇鎻掍欢甯傚満鏁版嵁澶辫触: {str(e)}"}



