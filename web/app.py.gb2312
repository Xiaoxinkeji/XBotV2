@app.get("/api/status")

async def get_status_api(username: str = Depends(get_current_username)):

    """鑾峰彇绯荤粺鐘舵€丄PI鎺ュ彛"""

    try:

        # 鑾峰彇鏈哄櫒浜虹姸锟?

        robot_status = get_robot_status()

        

        # 鑾峰彇绯荤粺淇℃伅

        system_info = {

            "cpu": psutil.cpu_percent(),

            "memory": psutil.Process().memory_info().rss,

            "memory_percent": psutil.virtual_memory().percent,

            "uptime": int(time.time() - psutil.boot_time())

        }

        

        # 鑾峰彇Redis杩炴帴鐘讹拷?

        try:

            # 妫€鏌ユ槸鍚﹀彲浠ヤ娇鐢╯ocket妯″潡

            has_socket = True

            try:

                import socket

            except ImportError:

                has_socket = False

            

            # 浣跨敤socket灏濊瘯杩炴帴Redis

            redis_running = False

            redis_error = "鏈娴嬪埌Socket锟?

            if has_socket:

                # 灏濊瘯绠€鍗曟鏌edis杩炴帴

                redis_host = config.get("WechatAPIServer", {}).get("redis-host", "127.0.0.1")

                redis_port = config.get("WechatAPIServer", {}).get("redis-port", 6379)

                

                s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)

                s.settimeout(1)

                try:

                    s.connect((redis_host, redis_port))

                    redis_running = True

                    redis_error = None

                except Exception as e:

                    redis_running = False

                    redis_error = f"鏃犳硶杩炴帴鍒癛edis鏈嶅姟锟? {redis_host}:{redis_port} - {str(e)}"

                    logger.warning(f"Redis杩炴帴澶辫触: {redis_error}")

                finally:

                    s.close()

        except Exception as e:

            redis_running = False

            redis_error = f"妫€鏌edis鐘舵€佹椂鍑洪敊: {str(e)}"

        

        system_info["redis"] = {

            "running": redis_running,

            "error": redis_error

        }

        

        # 鑾峰彇鎻掍欢淇℃伅

        plugins = get_plugins()

        enabled_plugins = [p for p in plugins if p['enabled']]

        

        plugin_info = {

            "total": len(plugins),

            "enabled": len(enabled_plugins),

            "disabled": len(plugins) - len(enabled_plugins)

        }

        

        # 鑾峰彇鐢ㄦ埛淇℃伅

        user_info = {

            "wxid": robot_status.get("wxid", ""),

            "nickname": robot_status.get("nickname", ""),

            "alias": robot_status.get("alias", ""),

            "login_time": get_login_time()

        }

        

        # 灏濊瘯娣诲姞澶村儚URL

        try:

            profile_path = PROJECT_ROOT / "resource" / "profile.json"

            if os.path.exists(profile_path):

                with open(profile_path, "r", encoding="utf-8") as f:

                    profile_data = json.load(f)

                    if "avatar_url" in profile_data:

                        user_info["avatar_url"] = profile_data["avatar_url"]

        except Exception as e:

            logger.warning(f"鑾峰彇澶村儚URL鏃跺嚭锟? {e}")

        

        # 鑾峰彇娑堟伅缁熻

        message_stats = get_message_stats()

        

        # 妫€鏌ユ満鍣ㄤ汉鐘舵€佸彉鍖栵紝瑙﹀彂閫氱煡

        check_robot_status_change(robot_status)

        

        # 杩斿洖瀹屾暣鐘舵€佷俊锟?

        return {

            "robot": robot_status,

            "system": system_info,

            "plugins": plugin_info,

            "user": user_info,

            "messages": message_stats

        }

    except Exception as e:

        logger.error(f"鑾峰彇鐘舵€佷俊鎭椂鍑洪敊: {e}")

        logger.error(traceback.format_exc())

        return {

            "robot": {"online": False, "error": str(e)},

            "system": {"error": "鑾峰彇绯荤粺淇℃伅澶辫触"},

            "plugins": {"total": 0, "enabled": 0, "disabled": 0},

            "user": {"wxid": "", "nickname": "鏈櫥锟?, "alias": ""},

            "messages": {"total": 0, "today": 0}

        }



