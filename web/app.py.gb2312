@app.get("/plugins", response_class=HTMLResponse)

async def plugins_page(request: Request, username: str = Depends(get_current_username)):

    """鎻掍欢绠＄悊椤甸潰"""

    try:

        # 鑾峰彇鎵€鏈夋彃浠朵俊锟?

        plugins_info = []

        plugins_dir = Path(BASE_DIR) / "plugins"

        

        if not plugins_dir.exists():

            logger.warning(f"鎻掍欢鐩綍涓嶅瓨锟? {plugins_dir}")

            # 鍒涘缓鎻掍欢鐩綍

            try:

                os.makedirs(plugins_dir, exist_ok=True)

                logger.info(f"宸插垱寤烘彃浠剁洰锟? {plugins_dir}")

            except Exception as e:

                logger.error(f"鍒涘缓鎻掍欢鐩綍澶辫触: {e}")

        

        if plugins_dir.exists() and plugins_dir.is_dir():

            for plugin_dir in plugins_dir.iterdir():

                if plugin_dir.is_dir() and (plugin_dir / "__init__.py").exists():

                    plugin_name = plugin_dir.name

                    plugin_info = {

                        "name": plugin_name,

                        "status": "宸插畨锟?,  # 榛樿鐘讹拷?

                        "version": "鏈煡",

                        "description": "鏃犳弿杩颁俊锟?

                    }

                    

                    # 灏濊瘯璇诲彇鎻掍欢锟?info.json 鏂囦欢鑾峰彇鏇村淇℃伅

                    info_file = plugin_dir / "info.json"

                    if info_file.exists():

                        try:

                            with open(info_file, "r", encoding="utf-8") as f:

                                info_data = json.load(f)

                                plugin_info.update(info_data)

                        except Exception as e:

                            logger.error(f"璇诲彇鎻掍欢 {plugin_name} 鐨勪俊鎭嚭锟? {e}")

                    

                    plugins_info.append(plugin_info)

        

        logger.info(f"娓叉煋鎻掍欢椤甸潰锛屽叡{len(plugins_info)}涓彃锟?)

        return templates.TemplateResponse("plugins.html", {

            "request": request, 

            "plugins": plugins_info,

            "admin_name": username

        })

    except Exception as e:

        logger.error(f"娓叉煋鎻掍欢椤甸潰鍑洪敊: {e}")

        logger.error(traceback.format_exc())

        # 杩斿洖閿欒椤甸潰鎴栧熀鏈彃浠堕〉锟?

        return templates.TemplateResponse("plugins.html", {

            "request": request, 

            "plugins": [],

            "error": str(e),

            "admin_name": username

        })



@app.get("/logs", response_class=HTMLResponse)

async def logs_page(request: Request, username: str = Depends(get_current_username)):

    """鏃ュ織鏌ョ湅椤甸潰"""

    try:

        # 鑾峰彇鏈€锟?0鏉℃棩锟?

        logs = get_recent_logs(20)

        

        # 纭繚姣忔潯鏃ュ織閮藉寘鍚繀瑕佺殑瀛楁

        formatted_logs = []

        for log in logs:

            # 纭繚鏃ュ織鏈夊繀瑕佺殑瀛楁

            if isinstance(log, dict) and "message" in log:

                if "timestamp" not in log:

                    log["timestamp"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

                if "level" not in log:

                    log["level"] = "INFO"

                formatted_logs.append(log)

        

        logger.info(f"娓叉煋鏃ュ織椤甸潰锛屽叡{len(formatted_logs)}鏉℃棩锟?)

        return templates.TemplateResponse("logs.html", {

            "request": request, 

            "logs": formatted_logs,

            "admin_name": username

        })

    except Exception as e:

        logger.error(f"娓叉煋鏃ュ織椤甸潰鍑洪敊: {e}")

        logger.error(traceback.format_exc())

        # 杩斿洖閿欒椤甸潰鎴栧熀鏈棩蹇楅〉锟?

        return templates.TemplateResponse("logs.html", {

            "request": request, 

            "logs": [

                {"timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"), 

                 "level": "ERROR", 

                 "message": f"鍔犺浇鏃ュ織鏃跺嚭锟? {str(e)}"}

            ],

            "error": str(e),

            "admin_name": username

        })



