@app.on_event("startup")

async def startup_plugin_repository():

    """鍚姩鏃跺垵濮嬪寲鎻掍欢浠撳簱"""

    # 纭繚鎵€鏈夊繀瑕佺洰褰曞瓨锟?

    ensure_directories()

    

    try:

        from database.plugin_repository import init_plugin_repository

        logger.info("鍒濆鍖栨彃浠朵粨锟?..")

        init_plugin_repository()

        logger.info("鎻掍欢浠撳簱鍒濆鍖栧畬锟?)

    except Exception as e:

        logger.error(f"鍒濆鍖栨彃浠朵粨搴撳け锟? {e}")

        logger.error(traceback.format_exc())



# 涓诲嚱锟?

def start_web_server():

    """鍚姩Web鏈嶅姟锟?""

    try:

        # 纭繚鐩綍瀛樺湪

        ensure_directories()

        

        # 鑾峰彇閰嶇疆

        config = get_config()

        web_config = config.get("WebInterface", {})

        

        host = web_config.get("host", "0.0.0.0")

        port = web_config.get("port", 8080)

        debug = web_config.get("debug", False)

        

        # 纭繚port鏄暣锟?

        try:

            port = int(port)

        except (ValueError, TypeError):

            logger.warning(f"绔彛閰嶇疆鏍煎紡涓嶆锟? {port}锛屼娇鐢ㄩ粯璁わ拷?080")

            port = 8080

        

        logger.info(f"鍚姩Web鏈嶅姟锟? {host}:{port}锛岃皟璇曟ā锟? {'寮€锟? if debug else '鍏抽棴'}")

        

        # 璁板綍绯荤粺淇℃伅

        import platform

        import psutil

        logger.info(f"鎿嶄綔绯荤粺: {platform.system()} {platform.release()} {platform.machine()}")

        logger.info(f"Python鐗堟湰: {platform.python_version()}")

        logger.info(f"绯荤粺鍐呭瓨: {psutil.virtual_memory().total / (1024*1024*1024):.2f} GB")

        logger.info(f"CPU淇℃伅: {platform.processor()} ({psutil.cpu_count()} 鏍稿績)")

        

        try:

            # 璁板綍涓昏渚濊禆鐗堟湰

            import fastapi

            import uvicorn

            import jinja2

            import sqlalchemy

            import loguru

            logger.info(f"渚濊禆鐗堟湰 - FastAPI: {fastapi.__version__}, Uvicorn: {uvicorn.__version__}, Jinja2: {jinja2.__version__}, SQLAlchemy: {sqlalchemy.__version__}")

        except Exception as dep_error:

            logger.warning(f"鑾峰彇渚濊禆鐗堟湰淇℃伅澶辫触: {dep_error}")

        

        # 鍚姩鏈嶅姟锟?

        try:

            uvicorn.run("web.app:app", host=host, port=port, reload=debug)

        except Exception as run_error:

            logger.error(f"uvicorn.run澶辫触: {run_error}")

            logger.error(traceback.format_exc())

            

            # 灏濊瘯澶囬€夊惎鍔ㄦ柟锟?

            import uvicorn.config

            import asyncio

            config = uvicorn.config.Config(app=app, host=host, port=port)

            server = uvicorn.Server(config)

            logger.info("浣跨敤澶囬€夋柟娉曞惎鍔ㄦ湇鍔″櫒")

            asyncio.run(server.serve())

            

    except Exception as e:

        logger.error(f"鍚姩Web鏈嶅姟鍣ㄥけ锟? {e}")

        logger.error(traceback.format_exc())

        raise



# 鍦ㄥ叾浠栭〉闈㈣矾鐢遍檮杩戞坊鍔犱互涓嬩唬锟?

