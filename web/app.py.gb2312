# 娣诲姞寮傚父澶勭悊绋嬪簭

@app.exception_handler(HTTPException)

async def http_exception_handler(request: Request, exc: HTTPException):

    """澶勭悊HTTP寮傚父锛屽鏋滄槸璁よ瘉閿欒鍒欓噸瀹氬悜鍒扮櫥褰曢〉锟?""

    if exc.status_code == 401:

        # 瀵逛簬API璺敱杩斿洖JSON鍝嶅簲

        if request.url.path.startswith("/api/"):

            return JSONResponse(

                status_code=exc.status_code,

                content={"detail": exc.detail, "success": False}

            )

        # 瀵逛簬椤甸潰璺敱閲嶅畾鍚戝埌鐧诲綍椤甸潰

        return RedirectResponse(url=f"/login?message={exc.detail}", status_code=303)

    

    # 澶勭悊鍏朵粬HTTP寮傚父

    if request.url.path.startswith("/api/"):

        return JSONResponse(

            status_code=exc.status_code,

            content={"detail": exc.detail, "success": False}

        )

    

    # 灏濊瘯鑾峰彇鐢ㄦ埛鍚嶏紙濡傛灉宸茬櫥褰曪級

    admin_name = None

    try:

        if hasattr(request, "session") and "username" in request.session:

            admin_name = request.session.get("username")

    except Exception:

        pass

    

    # 涓洪潪API璇锋眰杩斿洖鍙嬪ソ鐨勯敊璇〉锟?

    return templates.TemplateResponse(

        "error.html", 

        {

            "request": request, 

            "status_code": exc.status_code, 

            "error": f"閿欒 {exc.status_code}", 

            "message": exc.detail,

            "error_details": traceback.format_exc() if DEBUG else None,

            "admin_name": admin_name

        },

        status_code=exc.status_code

    )



@app.exception_handler(Exception)

async def general_exception_handler(request: Request, exc: Exception):

    """澶勭悊鎵€鏈夊叾浠栧紓锟?""

    # 璁板綍寮傚父

    logger.error(f"鏈鐞嗙殑寮傚父: {exc}")

    logger.error(traceback.format_exc())

    

    # 瀵逛簬API璺敱

    if request.url.path.startswith("/api/"):

        return JSONResponse(

            status_code=500,

            content={"detail": "鍐呴儴鏈嶅姟鍣ㄩ敊锟?, "message": str(exc), "success": False}

        )

    

    # 灏濊瘯鑾峰彇鐢ㄦ埛鍚嶏紙濡傛灉宸茬櫥褰曪級

    admin_name = None

    try:

        if hasattr(request, "session") and "username" in request.session:

            admin_name = request.session.get("username")

    except Exception:

        pass

    

    # 瀵逛簬甯歌椤甸潰璇锋眰

    return templates.TemplateResponse(

        "error.html", 

        {

            "request": request, 

            "status_code": 500, 

            "error": "鍐呴儴鏈嶅姟鍣ㄩ敊锟?, 

            "message": str(exc),

            "error_details": traceback.format_exc() if DEBUG else None,

            "admin_name": admin_name

        },

        status_code=500

    )



# 娣诲姞浼氳瘽涓棿锟?

