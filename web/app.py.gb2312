# 鑾峰彇绯荤粺杩愯鏃堕棿鐨勮緟鍔╁嚱锟?

def get_uptime():

    """鑾峰彇绯荤粺杩愯鏃堕棿"""

    try:

        boot_time = datetime.fromtimestamp(psutil.boot_time())

        uptime = datetime.now() - boot_time

        days, seconds = uptime.days, uptime.seconds

        hours = seconds // 3600

        minutes = (seconds % 3600) // 60

        return f"{days}锟?{hours}灏忔椂 {minutes}鍒嗛挓"

    except Exception as e:

        logger.error(f"鑾峰彇绯荤粺杩愯鏃堕棿鍑洪敊: {e}")

        return "鏈煡"



# 閰嶇疆鐩稿叧鍑芥暟

def get_config():

    """鑾峰彇褰撳墠閰嶇疆"""

    try:

        # 棣栧厛妫€鏌ユ槸鍚﹀彲浠ュ鍏onfig_utils

        try:

            from utils.config_utils import load_toml_config

        except ImportError:

            logger.error("鏃犳硶瀵煎叆config_utils妯″潡锛屽彲鑳芥槸璺緞闂")

            # 灏濊瘯鐩存帴瀵煎叆

            import sys

            import os

            sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

            try:

                from utils.config_utils import load_toml_config

                logger.info("閫氳繃璺緞璋冩暣鎴愬姛瀵煎叆config_utils")

            except ImportError as e:

                logger.error(f"璋冩暣璺緞鍚庝粛鏃犳硶瀵煎叆config_utils: {e}")

                return {

                    "WebInterface": {

                        "username": "admin",

                        "password": "admin123",

                        "enable": True,

                        "host": "0.0.0.0",

                        "port": 8080

                    }

                }

        

        # 灏濊瘯浠ヤ笉鍚岀殑鐩稿璺緞鏌ユ壘閰嶇疆鏂囦欢

        config_paths = [

            Path(BASE_DIR) / "main_config.toml",  # 鏍囧噯璺緞

            Path("main_config.toml"),            # 宸ヤ綔鐩綍

            Path("..") / "main_config.toml",     # 涓婄骇鐩綍

            Path(__file__).parent.parent / "main_config.toml"  # 鐩稿浜庤剼鏈殑璺緞

        ]

        

        config = None

        loaded_path = None

        

        for config_path in config_paths:

            logger.info(f"灏濊瘯璇诲彇閰嶇疆鏂囦欢: {config_path}")

            if config_path.exists():

                logger.info(f"鎵惧埌閰嶇疆鏂囦欢: {config_path}")

                loaded_path = config_path

                

                # 鐩存帴璇诲彇鏂囦欢鍐呭鐢ㄤ簬鏃ュ織璁板綍鍜岃皟锟?

                try:

                    with open(config_path, "r", encoding="utf-8") as f:

                        file_content = f.read()

                        logger.debug(f"閰嶇疆鏂囦欢鍐呭棰勮: {file_content[:100]}...")

                except Exception as read_error:

                    logger.error(f"鐩存帴璇诲彇閰嶇疆鏂囦欢澶辫触: {read_error}")

                

                # 浣跨敤缁熶竴閰嶇疆宸ュ叿鍔犺浇TOML

                config = load_toml_config(config_path)

                if config:

                    logger.info(f"锟?{config_path} 鎴愬姛鍔犺浇閰嶇疆")

                    break

        

        # 妫€鏌ラ厤缃槸鍚︽纭姞锟?

        if not config:

            logger.error("鎵€鏈夐厤缃枃浠惰矾寰勯兘澶辫触锛屼娇鐢ㄩ粯璁ら厤锟?)

            config = {

                "WebInterface": {

                    "username": "admin",

                    "password": "admin123",

                    "enable": True,

                    "host": "0.0.0.0",

                    "port": 8080,

                    "debug": False

                }

            }

        else:

            logger.info(f"閰嶇疆鏂囦欢 {loaded_path} 鍔犺浇鎴愬姛锛屽寘鍚殑閮ㄥ垎: {list(config.keys())}")

            

            # 妫€鏌ュ苟纭繚WebInterface閮ㄥ垎瀛樺湪涓斿寘鍚繀瑕佺殑锟?

            if "WebInterface" not in config:

                logger.warning("閰嶇疆鏂囦欢涓己灏慦ebInterface閮ㄥ垎锛屾坊鍔犻粯璁わ拷?)

                config["WebInterface"] = {

                    "username": "admin",

                    "password": "admin123",

                    "enable": True,

                    "host": "0.0.0.0",

                    "port": 8080,

                    "debug": False

                }

            else:

                web_config = config["WebInterface"]

                # 纭繚鍏抽敭閰嶇疆椤瑰瓨锟?

                if "username" not in web_config or not web_config["username"]:

                    web_config["username"] = "admin"

                if "password" not in web_config or not web_config["password"]:

                    web_config["password"] = "admin123"

                if "enable" not in web_config:

                    web_config["enable"] = True

                if "host" not in web_config:

                    web_config["host"] = "0.0.0.0"

                if "port" not in web_config:

                    web_config["port"] = 8080

                if "debug" not in web_config:

                    web_config["debug"] = False

        

        return config

        

    except Exception as e:

        logger.error(f"鑾峰彇閰嶇疆鏃跺嚭锟? {e}")

        logger.error(traceback.format_exc())

        # 杩斿洖榛樿閰嶇疆锛岀‘淇濆簲鐢ㄥ彲浠ョ户缁繍锟?

        return {

            "WebInterface": {

                "username": "admin",

                "password": "admin123",

                "enable": True,

                "host": "0.0.0.0",

                "port": 8080,

                "debug": False

            }

        }



# 鐢ㄦ埛璁よ瘉鐩稿叧鍑芥暟

security = HTTPBasic()



def get_current_username(request: Request):

    """鑾峰彇褰撳墠鐢ㄦ埛鍚嶏紝濡傛灉鏈櫥褰曞垯閲嶅畾鍚戝埌鐧诲綍椤甸潰"""

    try:

        # 妫€鏌ession鏄惁瀛樺湪

        if not hasattr(request, "session"):

            logger.error("璇锋眰瀵硅薄娌℃湁session灞烇拷?)

            raise HTTPException(

                status_code=401,

                detail="浼氳瘽鏃犳晥",

                headers={"WWW-Authenticate": "Basic"},

            )

            

        username = request.session.get("username")

        authenticated = request.session.get("authenticated", False)

        

        if not username or not authenticated:

            # 璁板綍鏈璇佺殑璇锋眰

            remote_addr = request.client.host if hasattr(request, "client") and hasattr(request.client, "host") else "unknown"

            logger.warning(f"鏈璇佺殑璇锋眰灏濊瘯璁块棶鍙椾繚鎶ょ殑璺敱锛屾潵婧怚P锛歿remote_addr}")

            

            # 杩斿洖401鐘舵€佺爜锛屽墠绔彲浠ユ崟鑾峰苟澶勭悊

            raise HTTPException(

                status_code=401,

                detail="鏈璇侊紝璇峰厛鐧诲綍",

                headers={"WWW-Authenticate": "Basic"},

            )

        

        return username

    except HTTPException:

        # 閲嶆柊鎶涘嚭HTTP寮傚父浠ヤ究FastAPI澶勭悊

        raise

    except Exception as e:

        # 澶勭悊浠讳綍鍏朵粬寮傚父

        logger.error(f"鑾峰彇褰撳墠鐢ㄦ埛鍚嶆椂鍑洪敊: {e}")

        logger.error(traceback.format_exc())

        

        # 杩斿洖閫氱敤閿欒

        raise HTTPException(

            status_code=500,

            detail=f"鍐呴儴鏈嶅姟鍣ㄩ敊锟? {str(e)}",

        )



@app.post("/auth")

async def authenticate(request: Request, 

                     username: str = Form(...), 

                     password: str = Form(...)):

    """澶勭悊鐧诲綍琛ㄥ崟鎻愪氦"""

    try:

        logger.info(f"鐢ㄦ埛灏濊瘯鐧诲綍: {username}")

        config = get_config()

        

        # 榛樿鍑嵁锛屼互闃查厤缃枃浠惰鍙栧け锟?

        default_username = "admin"

        default_password = "admin123"

        

        # 浠庨厤缃腑鑾峰彇鐢ㄦ埛鍚嶅拰瀵嗙爜

        if config and "WebInterface" in config:

            config_username = config["WebInterface"].get("username", default_username)

            config_password = config["WebInterface"].get("password", default_password)

        else:

            logger.warning("鏃犳硶浠庨厤缃腑璇诲彇鐢ㄦ埛鍚嶅拰瀵嗙爜锛屼娇鐢ㄩ粯璁わ拷?)

            config_username = default_username

            config_password = default_password

            

        # 娓呯悊杈撳叆鍜岄厤缃拷?

        username = username.strip()

        password = password.strip()

        config_username = config_username.strip()

        config_password = config_password.strip()

        

        # 璇︾粏鐧诲綍鏃ュ織锛屼笉璁板綍瀹屾暣瀵嗙爜

        logger.debug(f"杈撳叆鐨勭敤鎴峰悕: '{username}', 闀垮害: {len(username)}")

        logger.debug(f"杈撳叆鐨勫瘑鐮侀暱锟? {len(password)}")

        logger.debug(f"閰嶇疆鐨勭敤鎴峰悕: '{config_username}', 闀垮害: {len(config_username)}")

        logger.debug(f"閰嶇疆鐨勫瘑鐮侀暱锟? {len(config_password)}")

        

        # 妫€鏌ュ嚟鎹槸鍚﹀尮锟?

        if username == config_username and password == config_password:

            logger.info(f"鐢ㄦ埛 {username} 鐧诲綍鎴愬姛")

            # 璁剧疆浼氳瘽

            request.session["username"] = username

            request.session["authenticated"] = True

            request.session["login_time"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

            

            # 閲嶅畾鍚戝埌棣栭〉

            return RedirectResponse(url="/", status_code=303)

        else:

            # 灏濊瘯浣跨敤榛樿鍑嵁锛堝鏋滅敤鎴锋湭浣跨敤閰嶇疆涓殑鍑嵁锟?

            if username == default_username and password == default_password and (config_username != default_username or config_password != default_password):

                logger.warning(f"鐢ㄦ埛 {username} 浣跨敤榛樿鍑嵁鐧诲綍鎴愬姛")

                # 璁剧疆浼氳瘽

                request.session["username"] = username

                request.session["authenticated"] = True

                request.session["login_time"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

                

                # 閲嶅畾鍚戝埌棣栭〉锛屼絾甯︽湁璀﹀憡娑堟伅

                return RedirectResponse(url="/?message=鎮ㄤ娇鐢ㄤ簡榛樿鍑嵁鐧诲綍锛屽缓璁洿鏀瑰瘑锟?, status_code=303)

            

            logger.warning(f"鐢ㄦ埛 {username} 鐧诲綍澶辫触 - 鍑嵁涓嶅尮锟?)

            if username == config_username:

                logger.debug("鐢ㄦ埛鍚嶅尮閰嶏紝浣嗗瘑鐮佷笉鍖归厤")

            

            # 鐧诲綍澶辫触锛岄噸瀹氬悜鍥炵櫥褰曢〉锟?

            return RedirectResponse(url=f"/login?message=鐢ㄦ埛鍚嶆垨瀵嗙爜涓嶆锟?, status_code=303)

    except Exception as e:

        logger.error(f"鐧诲綍澶勭悊杩囩▼涓嚭锟? {e}")

        logger.error(traceback.format_exc())

        return RedirectResponse(url=f"/login?message=鐧诲綍澶勭悊鍑洪敊: {str(e)}", status_code=303)



# 妫€鏌ユ満鍣ㄤ汉鏄惁杩愯

def is_robot_running():

    # 妫€鏌ユ満鍣ㄤ汉杩涚▼鏄惁鍦ㄨ繍锟?

    if platform.system() == "Windows":

        # Windows骞冲彴

        for proc in psutil.process_iter(['pid', 'name']):

            if proc.info['name'] and "python" in proc.info['name'].lower():

                try:

                    cmdline = " ".join(proc.cmdline())

                    if "bot_core.py" in cmdline or "main.py" in cmdline:

                        return True, proc.pid

                except (psutil.NoSuchProcess, psutil.AccessDenied):

                    continue

    else:

        # Linux/macOS骞冲彴

        for proc in psutil.process_iter(['pid', 'cmdline']):

            try:

                cmdline = " ".join(proc.info['cmdline'] or [])

                if ("bot_core.py" in cmdline or "main.py" in cmdline) and "web/app.py" not in cmdline:

                    return True, proc.pid

            except (psutil.NoSuchProcess, psutil.AccessDenied):

                continue

    return False, None



# 鑾峰彇绯荤粺淇℃伅

def get_system_info():

    """鑾峰彇绯荤粺淇℃伅"""

    try:

        # 鑾峰彇绯荤粺鍩烘湰淇℃伅

        system_info = {

            "os": f"{platform.system()} {platform.release()}",

            "python_version": platform.python_version(),

            "hostname": platform.node(),

            "cpu_count": psutil.cpu_count(logical=True),

            "cpu_usage": round(psutil.cpu_percent(), 2),

            "memory_total": round(psutil.virtual_memory().total / (1024 * 1024 * 1024), 2),  # GB

            "memory_used": round(psutil.virtual_memory().used / (1024 * 1024 * 1024), 2),  # GB

            "memory_usage": round(psutil.virtual_memory().percent, 2),

            "disk_total": round(psutil.disk_usage('/').total / (1024 * 1024 * 1024), 2),  # GB

            "disk_used": round(psutil.disk_usage('/').used / (1024 * 1024 * 1024), 2),  # GB

            "disk_usage": round(psutil.disk_usage('/').percent, 2),

            "uptime": get_uptime(),

            "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        }

        

        return system_info

    except Exception as e:

        logger.error(f"鑾峰彇绯荤粺淇℃伅鏃跺嚭锟? {e}")

        return {

            "os": f"{platform.system()} {platform.release()}",

            "error": str(e),

            "time": datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        }



# 鑾峰彇鏈哄櫒浜虹姸锟?

def get_robot_status():

    """鑾峰彇鏈哄櫒浜虹姸锟?""

    try:

        # 杩欓噷搴旇鏄疄闄呮鏌ユ満鍣ㄤ汉鐘舵€佺殑浠ｇ爜

        # 涓虹畝鍖栵紝杩欓噷杩斿洖涓€涓ず渚嬬姸锟?

        return {

            "online": True,

            "wxid": "wxid_example",

            "nickname": "XBot鏈哄櫒锟?,

            "alias": "XBot",

            "plugin_count": 5,

            "message_count": 100

        }

    except Exception as e:

        logger.error(f"鑾峰彇鏈哄櫒浜虹姸鎬佸嚭锟? {e}")

        return {"online": False, "error": str(e)}



# 鑾峰彇鎵€鏈夋彃浠跺垪锟?

def get_plugins():

    """鑾峰彇鎻掍欢鍒楄〃"""

    try:

        plugins = []

        plugins_dir = Path(BASE_DIR) / "plugins"

        

        if not plugins_dir.exists():

            logger.warning(f"鎻掍欢鐩綍涓嶅瓨锟? {plugins_dir}")

            # 鍒涘缓鎻掍欢鐩綍

            try:

                os.makedirs(plugins_dir, exist_ok=True)

                logger.info(f"宸插垱寤烘彃浠剁洰锟? {plugins_dir}")

            except Exception as e:

                logger.error(f"鍒涘缓鎻掍欢鐩綍澶辫触: {e}")

        

        if plugins_dir.exists() and plugins_dir.is_dir():

            for plugin_dir in plugins_dir.iterdir():

                if plugin_dir.is_dir() and (plugin_dir / "__init__.py").exists():

                    plugin_name = plugin_dir.name

                    plugin = {

                        "name": plugin_name,

                        "enabled": True,  # 榛樿鍚敤

                        "description": "鏃犳弿杩颁俊锟?

                    }

                    

                    # 灏濊瘯璇诲彇鎻掍欢锟?info.json 鏂囦欢鑾峰彇鏇村淇℃伅

                    info_file = plugin_dir / "info.json"

                    if info_file.exists():

                        try:

                            with open(info_file, "r", encoding="utf-8") as f:

                                info = json.load(f)

                                if "name" in info:

                                    plugin["name"] = info["name"]

                                if "description" in info:

                                    plugin["description"] = info["description"]

                                if "version" in info:

                                    plugin["version"] = info["version"]

                                if "author" in info:

                                    plugin["author"] = info["author"]

                                if "enabled" in info:

                                    plugin["enabled"] = info["enabled"]

                        except Exception as e:

                            logger.error(f"璇诲彇鎻掍欢 {plugin_name} 淇℃伅鍑洪敊: {e}")

                    

                    plugins.append(plugin)

        

        return plugins

    except Exception as e:

        logger.error(f"鑾峰彇鎻掍欢鍒楄〃鍑洪敊: {e}")

        return []



# 鑾峰彇鎻掍欢閰嶇疆

def get_plugin_config(plugin_id: str):

    plugin_config_path = PROJECT_ROOT / "plugins" / plugin_id / "config.toml"

    if not plugin_config_path.exists():

        return None

    

    try:

        with open(plugin_config_path, "rb") as f:

            config_data = tomli.load(f)

        return config_data

    except:

        return None



# 瀹夎鎻掍欢

async def install_plugin(install_type: str, **kwargs):

    plugins_dir = PROJECT_ROOT / "plugins"

    

    # 纭繚鎻掍欢鐩綍瀛樺湪

    if not plugins_dir.exists():

        plugins_dir.mkdir(parents=True, exist_ok=True)

    

    try:

        if install_type == "git":

            git_url = kwargs.get("git_url")

            git_branch = kwargs.get("git_branch", "main")

            

            if not git_url:

                return {"success": False, "message": "鏈彁渚汫it浠撳簱URL"}

            

            # 浠嶶RL鑾峰彇鎻掍欢鍚嶇О

            plugin_name = git_url.rstrip("/").split("/")[-1]

            if plugin_name.endswith(".git"):

                plugin_name = plugin_name[:-4]

            

            plugin_dir = plugins_dir / plugin_name

            

            # 妫€鏌ョ洰鏍囩洰褰曟槸鍚﹀凡瀛樺湪

            if plugin_dir.exists():

                return {"success": False, "message": f"鎻掍欢鐩綍 {plugin_name} 宸插瓨锟?}

            

            # 鍏嬮殕Git浠撳簱

            subprocess.run(

                ["git", "clone", "-b", git_branch, git_url, str(plugin_dir)],

                check=True

            )

            

            # 妫€鏌ラ厤缃枃锟?

            plugin_config = get_plugin_config(plugin_name)

            if not plugin_config:

                # 鍒涘缓榛樿閰嶇疆

                default_config = {

                    "plugin": {

                        "name": plugin_name,

                        "description": "浠嶨it浠撳簱瀹夎鐨勬彃锟?,

                        "version": "1.0.0",

                        "author": "鏈煡"

                    }

                }

                

                with open(plugin_dir / "config.toml", "w") as f:

                    toml.dump(default_config, f)

            

            return {

                "success": True, 

                "message": f"鎻掍欢 {plugin_name} 宸插畨锟?,

                "plugin": {

                    "id": plugin_name,

                    "name": plugin_name,

                    "enabled": True

                }

            }

            

        elif install_type == "local":

            local_path = kwargs.get("local_path")

            

            if not local_path:

                return {"success": False, "message": "鏈彁渚涙湰鍦拌矾锟?}

            

            local_path = Path(local_path)

            if not local_path.exists():

                return {"success": False, "message": f"璺緞 {local_path} 涓嶅瓨锟?}

            

            if not local_path.is_dir():

                return {"success": False, "message": f"{local_path} 涓嶆槸鐩綍"}

            

            # 鑾峰彇鎻掍欢鍚嶇О

            plugin_name = local_path.name

            plugin_dir = plugins_dir / plugin_name

            

            # 妫€鏌ョ洰鏍囩洰褰曟槸鍚﹀凡瀛樺湪

            if plugin_dir.exists():

                return {"success": False, "message": f"鎻掍欢鐩綍 {plugin_name} 宸插瓨锟?}

            

            # 澶嶅埗鏂囦欢

            shutil.copytree(local_path, plugin_dir)

            

            # 妫€鏌ラ厤缃枃锟?

            plugin_config = get_plugin_config(plugin_name)

            if not plugin_config:

                # 鍒涘缓榛樿閰嶇疆

                default_config = {

                    "plugin": {

                        "name": plugin_name,

                        "description": "浠庢湰鍦板畨瑁呯殑鎻掍欢",

                        "version": "1.0.0",

                        "author": "鏈煡"

                    }

                }

                

                with open(plugin_dir / "config.toml", "w") as f:

                    toml.dump(default_config, f)

            

            return {

                "success": True, 

                "message": f"鎻掍欢 {plugin_name} 宸插畨锟?,

                "plugin": {

                    "id": plugin_name,

                    "name": plugin_name,

                    "enabled": True

                }

            }

            

        elif install_type == "zip":

            zip_url = kwargs.get("zip_url")

            

            if not zip_url:

                return {"success": False, "message": "鏈彁渚沍IP鏂囦欢URL"}

            

            # 浠嶶RL鑾峰彇鎻掍欢鍚嶇О

            plugin_name = zip_url.rstrip("/").split("/")[-1]

            if plugin_name.endswith(".zip"):

                plugin_name = plugin_name[:-4]

            

            plugin_dir = plugins_dir / plugin_name

            

            # 妫€鏌ョ洰鏍囩洰褰曟槸鍚﹀凡瀛樺湪

            if plugin_dir.exists():

                return {"success": False, "message": f"鎻掍欢鐩綍 {plugin_name} 宸插瓨锟?}

            

            # 鍒涘缓涓存椂鐩綍

            import tempfile

            temp_dir = tempfile.mkdtemp()

            temp_zip = os.path.join(temp_dir, "plugin.zip")

            

            # 涓嬭浇ZIP鏂囦欢

            async with httpx.AsyncClient() as client:

                response = await client.get(zip_url)

                if response.status_code != 200:

                    return {"success": False, "message": f"涓嬭浇ZIP鏂囦欢澶辫触: {response.status_code}"}

                

                with open(temp_zip, "wb") as f:

                    f.write(response.content)

            

            # 瑙ｅ帇ZIP鏂囦欢

            import zipfile

            with zipfile.ZipFile(temp_zip, "r") as zip_ref:

                zip_ref.extractall(temp_dir)

            

            # 鎵惧埌涓荤洰锟?

            extracted_dirs = [d for d in os.listdir(temp_dir) if os.path.isdir(os.path.join(temp_dir, d))]

            if len(extracted_dirs) == 1:

                # 鍙湁涓€涓洰褰曪紝浣跨敤璇ョ洰锟?

                main_dir = os.path.join(temp_dir, extracted_dirs[0])

            else:

                # 鏈夊涓洰褰曪紝鎵惧埌鍖呭惈__init__.py鐨勭洰锟?

                main_dir = None

                for d in extracted_dirs:

                    if os.path.exists(os.path.join(temp_dir, d, "__init__.py")):

                        main_dir = os.path.join(temp_dir, d)

                        break

                

                # 濡傛灉娌℃湁鎵惧埌锛屼娇鐢╰emp_dir

                if not main_dir:

                    main_dir = temp_dir

            

            # 澶嶅埗鏂囦欢

            shutil.copytree(main_dir, plugin_dir)

            

            # 妫€鏌ラ厤缃枃锟?

            plugin_config = get_plugin_config(plugin_name)

            if not plugin_config:

                # 鍒涘缓榛樿閰嶇疆

                default_config = {

                    "plugin": {

                        "name": plugin_name,

                        "description": "浠嶼IP鏂囦欢瀹夎鐨勬彃锟?,

                        "version": "1.0.0",

                        "author": "鏈煡"

                    }

                }

                

                with open(plugin_dir / "config.toml", "w") as f:

                    toml.dump(default_config, f)

            

            # 娓呯悊涓存椂鏂囦欢

            shutil.rmtree(temp_dir)

            

            return {

                "success": True, 

                "message": f"鎻掍欢 {plugin_name} 宸插畨锟?,

                "plugin": {

                    "id": plugin_name,

                    "name": plugin_name,

                    "enabled": True

                }

            }

            

        else:

            return {"success": False, "message": f"涓嶆敮鎸佺殑瀹夎绫诲瀷: {install_type}"}

            

    except Exception as e:

        logger.error(f"瀹夎鎻掍欢澶辫触: {e}")

        return {"success": False, "message": f"瀹夎鎻掍欢澶辫触: {str(e)}"}



# 鍒犻櫎鎻掍欢

def delete_plugin(plugin_id: str, delete_files: bool = False):

    # 璇诲彇閰嶇疆

    with open(config_path, "rb") as f:

        current_config = tomli.load(f)

    

    disabled_plugins = current_config.get("XYBot", {}).get("disabled-plugins", [])

    

    # 妫€鏌ユ彃浠舵槸鍚﹀瓨锟?

    plugin_dir = PROJECT_ROOT / "plugins" / plugin_id

    if not plugin_dir.is_dir():

        return {"success": False, "message": f"鎻掍欢 {plugin_id} 涓嶅瓨锟?}

    

    try:

        # 濡傛灉鍦ㄧ鐢ㄥ垪琛ㄤ腑锛岀Щ锟?

        if plugin_id in disabled_plugins:

            disabled_plugins.remove(plugin_id)

            current_config["XYBot"]["disabled-plugins"] = disabled_plugins

            

            with open(config_path, "w", encoding="utf-8") as f:

                toml.dump(current_config, f)

        

        # 濡傛灉闇€瑕佸垹闄ゆ枃锟?

        if delete_files:

            shutil.rmtree(plugin_dir)

        

        return {"success": True, "message": f"鎻掍欢 {plugin_id} 宸插垹锟?}

    except Exception as e:

        logger.error(f"鍒犻櫎鎻掍欢澶辫触: {e}")

        return {"success": False, "message": f"鍒犻櫎鎻掍欢澶辫触: {str(e)}"}



# 鏇存柊鎻掍欢

async def update_plugin(plugin_id: str):

    plugin_dir = PROJECT_ROOT / "plugins" / plugin_id

    

    # 妫€鏌ユ彃浠舵槸鍚﹀瓨锟?

    if not plugin_dir.is_dir():

        return {"success": False, "message": f"鎻掍欢 {plugin_id} 涓嶅瓨锟?}

    

    # 妫€鏌ユ槸鍚︿负Git浠撳簱

    git_dir = plugin_dir / ".git"

    if not git_dir.is_dir():

        return {"success": False, "message": f"鎻掍欢 {plugin_id} 涓嶆槸Git浠撳簱"}

    

    try:

        # 鑾峰彇褰撳墠鍒嗘敮

        result = subprocess.run(

            ["git", "-C", str(plugin_dir), "branch", "--show-current"],

            capture_output=True,

            text=True,

            check=True

        )

        current_branch = result.stdout.strip()

        

        # 鎷夊彇鏈€鏂颁唬锟?

        subprocess.run(

            ["git", "-C", str(plugin_dir), "pull", "origin", current_branch],

            check=True

        )

        

        return {"success": True, "message": f"鎻掍欢 {plugin_id} 宸叉洿锟?}

    except Exception as e:

        logger.error(f"鏇存柊鎻掍欢澶辫触: {e}")

        return {"success": False, "message": f"鏇存柊鎻掍欢澶辫触: {str(e)}"}



# 鎺у埗鏈哄櫒锟?

def control_robot(action: str):

    if action not in ["start", "stop", "restart"]:

        logger.warning(f"鏀跺埌涓嶆敮鎸佺殑鏈哄櫒浜烘帶鍒舵搷锟? {action}")

        return {"success": False, "message": f"涓嶆敮鎸佺殑鎿嶄綔: {action}"}

    

    try:

        logger.info(f"鎵ц鏈哄櫒浜烘帶鍒舵搷锟? {action}")

        

        if action == "start":

            # 妫€鏌ユ槸鍚﹀凡缁忓湪杩愯

            running, pid = is_robot_running()

            if running:

                logger.warning("鏈哄櫒浜哄凡鍦ㄨ繍琛岋紝鏃犻渶閲嶅鍚姩")

                return {"success": False, "message": "鏈哄櫒浜哄凡鍦ㄨ繍锟?, "status": "running", "pid": pid}

            

            logger.info("姝ｅ湪鍚姩鏈哄櫒锟?..")

            

            # 鏋勫缓鍚姩鍛戒护

            cmd = []

            if platform.system() == "Windows":

                cmd = ["python", "main.py"]

            else:

                cmd = ["python3", "main.py"]

            

            # 娣诲姞鐜鍙橀噺锛岀‘淇濅娇鐢ㄦ纭殑Python鍜岃祫婧愯矾锟?

            env = os.environ.copy()

            env["PYTHONPATH"] = str(PROJECT_ROOT)

            

            # 鍚姩鏈哄櫒锟?

            try:

                process = subprocess.Popen(

                    cmd, 

                    cwd=str(PROJECT_ROOT),

                    env=env,

                    stdout=subprocess.PIPE if platform.system() == "Windows" else subprocess.DEVNULL,

                    stderr=subprocess.PIPE if platform.system() == "Windows" else subprocess.DEVNULL,

                    creationflags=subprocess.CREATE_NO_WINDOW if platform.system() == "Windows" else 0

                )

                

                logger.info(f"鏈哄櫒浜鸿繘绋嬪惎鍔紝PID: {process.pid}")

                

                # 绛夊緟鍚姩

                wait_time = 0

                max_wait = 10  # 鏈€澶氱瓑锟?0锟?

                check_interval = 0.5  # 锟?.5绉掓鏌ヤ竴锟?

                

                while wait_time < max_wait:

                    time.sleep(check_interval)

                    wait_time += check_interval

                    

                    # 妫€鏌ヨ繘绋嬫槸鍚︿粛鍦ㄨ繍锟?

                    if process.poll() is not None:

                        # 杩涚▼宸查€€锟?

                        stdout, stderr = process.communicate()

                        logger.error(f"鏈哄櫒浜鸿繘绋嬪惎鍔ㄥけ锟? 閫€鍑虹爜: {process.returncode}")

                        logger.error(f"鏍囧噯杈撳嚭: {stdout.decode('utf-8', errors='ignore') if stdout else ''}")

                        logger.error(f"鏍囧噯閿欒: {stderr.decode('utf-8', errors='ignore') if stderr else ''}")

                        return {"success": False, "message": f"鍚姩鏈哄櫒浜哄け璐ワ紝杩涚▼寮傚父閫€鍑猴紝杩斿洖锟? {process.returncode}"}

                    

                    # 妫€鏌ユ槸鍚﹀凡鎴愬姛鍚姩

                    running, new_pid = is_robot_running()

                    if running:

                        logger.info(f"鏈哄櫒浜哄凡鎴愬姛鍚姩锛孭ID: {new_pid}")

                        

                        # 鑾峰彇鐘舵€佸苟瑙﹀彂閫氱煡

                        status = get_robot_status()

                        

                        return {"success": True, "message": "鏈哄櫒浜哄凡鍚姩", "pid": new_pid}

                

                # 瓒呰繃鏈€澶х瓑寰呮椂锟?

                logger.warning("鏈哄櫒浜哄惎鍔ㄨ秴鏃讹紝浣嗚繘绋嬩粛鍦ㄨ繍琛屻€傝妫€鏌ユ棩蹇楃‘璁ゆ槸鍚︽甯歌繍琛岋拷?)

                return {"success": True, "message": "鏈哄櫒浜哄凡鍚姩锛屼絾灏氭湭妫€娴嬪埌灏辩华鐘舵€侊紝璇风◢鍚庡啀妫€鏌ワ拷?, "pid": process.pid}

                

            except Exception as e:

                logger.error(f"鍚姩鏈哄櫒浜烘椂鍙戠敓寮傚父: {e}")

                return {"success": False, "message": f"鍚姩鏈哄櫒浜哄け锟? {str(e)}"}

                

        elif action == "stop":

            # 妫€鏌ユ槸鍚﹀湪杩愯

            running, pid = is_robot_running()

            if not running:

                logger.warning("鏈哄櫒浜烘湭鍦ㄨ繍琛岋紝鏃犳硶鍋滄")

                return {"success": False, "message": "鏈哄櫒浜烘湭鍦ㄨ繍锟?}

            

            # 鍏堣幏鍙栧綋鍓嶇姸鎬侊紝鐢ㄤ簬涔嬪悗鐨勯€氱煡

            current_status = get_robot_status()

            

            logger.info(f"姝ｅ湪鍋滄鏈哄櫒浜鸿繘锟?(PID: {pid})...")

            

            try:

                # 鑾峰彇杩涚▼瀵硅薄

                process = psutil.Process(pid)

                

                # 鑾峰彇瀛愯繘锟?

                children = process.children(recursive=True)

                

                # 鍏堟甯哥粓姝富杩涚▼

                process.terminate()

                

                # 绛夊緟杩涚▼缁堟

                gone, still_alive = psutil.wait_procs([process], timeout=5)

                

                if still_alive:

                    # 濡傛灉杩涚▼鏈粓姝紝寮哄埗缁堟

                    logger.warning(f"杩涚▼ {pid} 鏈搷搴旂粓姝俊鍙凤紝姝ｅ湪寮哄埗缁堟...")

                    for p in still_alive:

                        p.kill()

                

                # 缁堟鎵€鏈夊瓙杩涚▼

                if children:

                    logger.info(f"姝ｅ湪缁堟 {len(children)} 涓瓙杩涚▼...")

                    for child in children:

                        try:

                            child.terminate()

                        except psutil.NoSuchProcess:

                            pass

                    

                    # 绛夊緟瀛愯繘绋嬬粓锟?

                    gone, still_alive = psutil.wait_procs(children, timeout=3)

                    

                    # 寮哄埗缁堟浠嶅湪杩愯鐨勫瓙杩涚▼

                    if still_alive:

                        for p in still_alive:

                            try:

                                p.kill()

                            except psutil.NoSuchProcess:

                                pass

                

                logger.info("鏈哄櫒浜哄凡鎴愬姛鍋滄")

                

                # 鏇存柊鐘舵€侊紝浣嗕笉鐩存帴鍙戦€侀€氱煡

                # API绔偣浼氬湪涓嬫璇锋眰鏃舵娴嬬姸鎬佸彉鍖栧苟鍙戦€侀€氱煡

                current_status["online"] = False

                

                return {"success": True, "message": "鏈哄櫒浜哄凡鍋滄"}

                

            except psutil.NoSuchProcess:

                logger.warning(f"杩涚▼ {pid} 涓嶅瓨鍦紝鍙兘宸茬粡缁堟")

                return {"success": True, "message": "鏈哄櫒浜哄凡鍋滄锛堣繘绋嬩笉瀛樺湪锟?}

                

            except Exception as e:

                logger.error(f"鍋滄鏈哄櫒浜烘椂鍙戠敓寮傚父: {e}")

                return {"success": False, "message": f"鍋滄鏈哄櫒浜哄け锟? {str(e)}"}

            

        elif action == "restart":

            logger.info("姝ｅ湪閲嶅惎鏈哄櫒锟?..")

            

            # 鍏堣幏鍙栧綋鍓嶇姸鎬侊紝鐢ㄤ簬涔嬪悗鐨勯€氱煡

            current_status = get_robot_status().copy()

            

            # 鍏堝仠锟?

            stop_result = control_robot("stop")

            if not stop_result["success"]:

                logger.warning(f"鍋滄鏈哄櫒浜哄け锟? {stop_result['message']}")

                # 濡傛灉鏄洜涓烘満鍣ㄤ汉鏈繍琛岃€屽仠姝㈠け璐ワ紝鍒欑户缁惎锟?

                if "鏈湪杩愯" not in stop_result["message"]:

                    return {"success": False, "message": f"閲嶅惎澶辫触: {stop_result['message']}"}

            

            # 绛夊緟瀹屽叏鍋滄

            time.sleep(2)

            

            # 鍚姩

            start_result = control_robot("start")

            

            # 杩斿洖鍚姩缁撴灉

            if start_result["success"]:

                logger.info("鏈哄櫒浜哄凡鎴愬姛閲嶅惎")

                start_result["message"] = "鏈哄櫒浜哄凡閲嶅惎"

            else:

                logger.error(f"閲嶅惎鏈哄櫒浜哄け锟? {start_result['message']}")

                start_result["message"] = f"閲嶅惎鏈哄櫒浜哄け锟? {start_result['message']}"

            

            return start_result

    

    except Exception as e:

        logger.error(f"鎺у埗鏈哄櫒浜哄け锟? {e}", exc_info=True)

        return {"success": False, "message": f"鎺у埗鏈哄櫒浜哄け锟? {str(e)}"}



# 鑾峰彇浜岀淮鐮乁RL

def get_qrcode_from_logs():

    """浠庢渶鏂扮殑鏃ュ織鏂囦欢涓幏鍙栫櫥褰曚簩缁寸爜URL"""

    logger.info("寮€濮嬩粠鏃ュ織涓煡鎵句簩缁寸爜URL")

    

    # 灏濊瘯澶氫釜鍙兘鐨勬棩蹇椾綅锟?

    possible_log_dirs = [

        Path(PROJECT_ROOT) / "logs",

        Path(PROJECT_ROOT) / "log",

        Path(PROJECT_ROOT),

        Path("/var/log/xbotv2"),

        Path("/logs"),

        Path(".")

    ]

    

    log_files = []

    

    # 妫€鏌ュ悇涓彲鑳界殑鏃ュ織鐩綍

    for log_dir in possible_log_dirs:

        if log_dir.exists() and log_dir.is_dir():

            logger.info(f"鎼滅储鏃ュ織鐩綍: {log_dir}")

            # 鑾峰彇璇ョ洰褰曚笅鎵€锟?log鏂囦欢

            files = list(log_dir.glob("*.log"))

            if files:

                log_files.extend(files)

                logger.info(f"锟?{log_dir} 鍙戠幇 {len(files)} 涓棩蹇楁枃锟?)

    

    if not log_files:

        logger.warning("鏈壘鍒颁换浣曟棩蹇楁枃锟?)

        return None

    

    # 鎸変慨鏀规椂闂存帓搴忥紝鏈€鏂扮殑浼樺厛

    log_files.sort(key=lambda x: x.stat().st_mtime, reverse=True)

    

    if log_files:

        logger.info(f"鍏辨壘锟?{len(log_files)} 涓棩蹇楁枃浠讹紝鎸変慨鏀规椂闂存帓锟?)

    else:

        logger.warning("娌℃湁鎵惧埌浠讳綍鏃ュ織鏂囦欢")

        return None

    

    # 浠庢渶鏂扮殑鏃ュ織鏂囦欢寮€濮嬫煡鎵句簩缁寸爜URL

    qr_pattern = re.compile(r'(https?://[^\s]+\.png|https?://[^\s]+weixin[^\s]+)')

    

    for log_file in log_files[:5]:  # 鍙鏌ユ渶鏂扮殑5涓枃锟?

        try:

            logger.info(f"妫€鏌ユ棩蹇楁枃锟? {log_file}")

            with open(log_file, "r", encoding="utf-8", errors="ignore") as f:

                lines = f.readlines()

            

            # 鍊掑簭鏌ユ壘锛屾渶鏂扮殑鏃ュ織鏉＄洰鍦ㄦ枃浠舵湯锟?

            for line in reversed(lines):

                if "浜岀淮锟? in line or "qrcode" in line.lower() or "weixin" in line.lower() or ".png" in line:

                    match = qr_pattern.search(line)

                    if match:

                        qr_url = match.group(0)

                        logger.info(f"鍦ㄦ棩蹇椾腑鎵惧埌浜岀淮鐮乁RL: {qr_url[:30]}...")

                        return qr_url

        except Exception as e:

            logger.error(f"璇诲彇鏃ュ織鏂囦欢 {log_file} 鏃跺嚭锟? {e}")

            continue

    

    logger.warning("鍦ㄦ墍鏈夋棩蹇楁枃浠朵腑鏈壘鍒颁簩缁寸爜URL")

    return None



# 鑾峰彇鏈€杩戞棩蹇楀唴锟?

def get_recent_logs(limit=10, search=None, level=None):

    global _logs_cache

    

    # 纭繚_logs_cache鍖呭惈鎵€鏈夊繀闇€鐨勫瓧锟?

    if not _logs_cache:

        _logs_cache = {

            'last_update': 0,

            'logs': [],

            'cache_timeout': 5  # 榛樿缂撳瓨瓒呮椂鏃堕棿锟?锟?

        }

    elif 'cache_timeout' not in _logs_cache:

        _logs_cache['cache_timeout'] = 5

    

    # 妫€鏌ョ紦瀛樻槸鍚︽湁锟?

    current_time = time.time()

    if (_logs_cache and 

        'last_update' in _logs_cache and

        _logs_cache['last_update'] > current_time - _logs_cache.get("cache_timeout", 5) and

        'logs' in _logs_cache):

        logs = _logs_cache['logs']

        if search or level:

            logs = filter_logs(logs, search, level)

        return logs[:limit]

    

    logs = []

    

    # 鍙兘鐨勬棩蹇楃洰锟?

    log_dirs = ['logs', 'log', '../logs', os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'logs')]

    

    # 娣诲姞缁濆璺緞

    absolute_paths = ['/var/log/xbotv2', '/app/logs']

    for path in absolute_paths:

        if os.path.exists(path) and os.path.isdir(path):

            log_dirs.append(path)

    

    # 瀵绘壘鏃ュ織鏂囦欢

    log_files = []

    

    # 鐗瑰畾鐨勬棩蹇楁枃浠跺悕妯″紡

    patterns = ['XYBot_*.log', '*.log']

    

    for log_dir in log_dirs:

        for pattern in patterns:

            try:

                if os.path.exists(log_dir) and os.path.isdir(log_dir):

                    pattern_path = os.path.join(log_dir, pattern)

                    matching_files = glob.glob(pattern_path)

                    if matching_files:

                        # 鎸変慨鏀规椂闂存帓搴忥紝鏈€鏂扮殑鍦ㄥ墠

                        matching_files.sort(key=os.path.getmtime, reverse=True)

                        log_files.extend(matching_files)

            except Exception as e:

                logs.append({

                    "time": time.strftime('%Y-%m-%d %H:%M:%S'), 

                    "level": "ERROR", 

                    "content": f"鎼滅储鏃ュ織鏂囦欢鏃跺嚭锟?{log_dir}/{pattern}: {str(e)}"

                })

    

    if not log_files:

        # 濡傛灉娌℃湁鎵惧埌鏃ュ織鏂囦欢锛岃繑鍥炴彁绀轰俊锟?

        sample_logs = []

        

        # 娣诲姞绀轰緥鏃ュ織鍜岃锟?

        current_time = time.strftime('%Y-%m-%d %H:%M:%S')

        sample_logs.append({

            "time": current_time, 

            "level": "WARNING", 

            "content": "鏈壘鍒版棩蹇楁枃浠躲€傝妫€鏌ヤ互涓嬬洰褰曪細"

        })

        

        for log_dir in log_dirs:

            sample_logs.append({

                "time": current_time, 

                "level": "INFO", 

                "content": f"- {os.path.abspath(log_dir)}"

            })

            

        sample_logs.append({

            "time": current_time, 

            "level": "INFO", 

            "content": "浣跨敤鏃ュ織妯″紡: " + ", ".join(patterns)

        })

        

        sample_logs.append({

            "time": current_time, 

            "level": "WARNING", 

            "content": "璇风‘淇漍YBot姝ｅ湪杩愯骞剁敓鎴愭棩蹇楁枃锟?

        })

        

        # 娣诲姞绀轰緥浜岀淮鐮乁RL

        qr_time = current_time

        qr_example = f"璇蜂娇鐢ㄥ井淇℃壂鎻忎簩缁寸爜鐧诲綍: https://open.weixin.qq.com/connect/qrconnect?appid=example"

        sample_logs.append({

            "time": qr_time, 

            "level": "INFO", 

            "content": qr_example

        })

        

        # 鏇存柊缂撳瓨

        _logs_cache = {

            'last_update': current_time,

            'logs': sample_logs,

            'cache_timeout': 5  # 娣诲姞缂撳瓨瓒呮椂

        }

        

        # 杩斿洖杩囨护鍚庣殑鏍锋湰鏃ュ織

        filtered_logs = filter_logs(sample_logs, search, level) if (search or level) else sample_logs

        return filtered_logs[:limit]

    

    # 璇诲彇鏈€鏂扮殑鏃ュ織鏂囦欢鍐呭

    logs = []

    

    # 鏈€澶氳鍙栧墠5涓棩蹇楁枃锟?

    for log_file in log_files[:5]:

        try:

            # 鑾峰彇鏂囦欢澶у皬

            file_size = os.path.getsize(log_file)

            

            # 濡傛灉鏂囦欢澶ぇ锛屽彧璇诲彇鏈熬鐨勯儴锟?

            read_size = min(file_size, 50 * 1024)  # 鏈€澶氳锟?0KB

            

            with open(log_file, 'r', encoding='utf-8', errors='ignore') as f:

                if read_size < file_size:

                    f.seek(file_size - read_size)

                    # 涓㈠純绗竴琛岋紝鍥犱负鍙兘鏄笉瀹屾暣锟?

                    f.readline()

                

                lines = f.readlines()

                

                # 澶勭悊姣忎竴琛屾棩锟?

                for line in lines:

                    line = line.strip()

                    if not line:

                        continue

                    

                    # 灏濊瘯瑙ｆ瀽鏃ュ織锟?

                    log_entry = parse_log_line(line)

                    if log_entry:

                        logs.append(log_entry)

                    else:

                        # 濡傛灉鏃犳硶瑙ｆ瀽锛屼綔涓虹函鏂囨湰娣诲姞

                        logs.append({

                            "time": time.strftime('%Y-%m-%d %H:%M:%S'),

                            "level": "INFO",

                            "content": line

                        })

        except Exception as e:

            # 璁板綍璇诲彇鏃ュ織鏂囦欢鏃剁殑閿欒

            logger.error(f"璇诲彇鏃ュ織鏂囦欢 {log_file} 鏃跺嚭锟? {str(e)}")

            logs.append({

                "time": time.strftime('%Y-%m-%d %H:%M:%S'),

                "level": "ERROR",

                "content": f"璇诲彇鏃ュ織鏂囦欢 {os.path.basename(log_file)} 鏃跺嚭锟? {str(e)}"

            })

    

    # 鎸夋椂闂存帓搴忥紝鏈€鏂扮殑鍦ㄥ墠

    logs.sort(key=lambda x: x.get('time', ''), reverse=True)

    

    # 璁板綍鎵惧埌鐨勬棩蹇楁暟锟?

    logger.info(f"API鑾峰彇锟?{len(logs)} 鏉℃棩锟?)

    

    # 鏇存柊缂撳瓨

    _logs_cache = {

        'last_update': time.time(),

        'logs': logs,

        'cache_timeout': 5  # 鍒锋柊缂撳瓨瓒呮椂

    }

    

    # 杩斿洖杩囨护鍚庣殑鏃ュ織

    filtered_logs = filter_logs(logs, search, level) if (search or level) else logs

    return filtered_logs[:limit]



# 瑙ｆ瀽鏃ュ織锟?

def parse_log_line(line):

    try:

        # 灏濊瘯澶氱鏃ュ織鏍煎紡

        # 鏍煎紡1: [2023-09-10 15:20:45] [INFO] 鏃ュ織鍐呭

        match1 = re.match(r'\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] \[([A-Z]+)\] (.*)', line)

        if match1:

            return {

                "time": match1.group(1),

                "level": match1.group(2),

                "content": match1.group(3)

            }

        

        # 鏍煎紡2: 2023-09-10 15:20:45 | INFO | 鏃ュ織鍐呭

        match2 = re.match(r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) \| ([A-Z]+) \| (.*)', line)

        if match2:

            return {

                "time": match2.group(1),

                "level": match2.group(2),

                "content": match2.group(3)

            }

        

        # 鏍煎紡3: 2023/09/10 15:20:45 [INFO] 鏃ュ織鍐呭

        match3 = re.match(r'(\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2}) \[([A-Z]+)\] (.*)', line)

        if match3:

            return {

                "time": match3.group(1).replace('/', '-'),

                "level": match3.group(2),

                "content": match3.group(3)

            }

        

        # 鏍煎紡4: [15:20:45] [INFO] 鏃ュ織鍐呭 (娌℃湁鏃ユ湡鐨勬儏锟?

        match4 = re.match(r'\[(\d{2}:\d{2}:\d{2})\] \[([A-Z]+)\] (.*)', line)

        if match4:

            today = time.strftime('%Y-%m-%d')

            return {

                "time": f"{today} {match4.group(1)}",

                "level": match4.group(2),

                "content": match4.group(3)

            }

        

        # 濡傛灉鏃犳硶鍖归厤浠讳綍鏍煎紡锛岃繑鍥濶one

        return None

    except Exception as e:

        logger.error(f"瑙ｆ瀽鏃ュ織琛屽嚭锟? {str(e)} - 琛屽唴锟? {line}")

        return None



# 璺敱瀹氫箟

@app.get("/", response_class=HTMLResponse)

async def home(request: Request, username: str = Depends(get_current_username)):

    """棣栭〉/浠〃锟?""

    try:

        # 鑾峰彇鏈哄櫒浜虹姸锟?

        robot_status = get_robot_status()

        

        # 鑾峰彇绯荤粺淇℃伅

        system_info = {

            "os": platform.system() + " " + platform.release(),

            "python": platform.python_version(),

            "uptime": get_uptime(),

            "cpu_usage": psutil.cpu_percent(),

            "memory_usage": psutil.virtual_memory().percent,

            "disk_usage": psutil.disk_usage('/').percent

        }

        

        # 鑾峰彇鏈€杩戠殑鏃ュ織

        recent_logs = get_recent_logs(5)

        

        # 鑾峰彇褰撳墠閰嶇疆淇℃伅

        config = get_config()

        

        logger.info("娓叉煋棣栭〉/浠〃鏉块〉锟?)

        return templates.TemplateResponse("index.html", {

            "request": request,

            "robot": robot_status,

            "system": system_info,

            "logs": recent_logs,

            "config": config,

            "admin_name": username

        })

    except Exception as e:

        logger.error(f"娓叉煋棣栭〉鍑洪敊: {e}")

        logger.error(traceback.format_exc())

        # 杩斿洖鍩烘湰椤甸潰淇℃伅

        return templates.TemplateResponse("index.html", {

            "request": request,

            "robot": {"status": "鏈煡", "error": str(e)},

            "system": {"error": str(e)},

            "logs": [],

            "config": {},

            "admin_name": username

        })



@app.get("/login", response_class=HTMLResponse)

async def login_page(request: Request, message: str = None):

    """鐢ㄦ埛鐧诲綍椤甸潰"""

    try:

        # 妫€鏌ョ敤鎴锋槸鍚﹀凡缁忕櫥锟?

        if "authenticated" in request.session and request.session.get("authenticated", False):

            # 宸茬櫥褰曪紝閲嶅畾鍚戝埌棣栭〉

            return RedirectResponse(url="/", status_code=303)

        

        # 鏈櫥褰曪紝鏄剧ず鐧诲綍椤甸潰

        return templates.TemplateResponse(

            "user_login.html", 

            {

                "request": request,

                "message": message

            }

        )

    except Exception as e:

        logger.error(f"鍔犺浇鐧诲綍椤甸潰澶辫触: {e}")

        logger.error(traceback.format_exc())

        return HTMLResponse(f"<h1>鍔犺浇鐧诲綍椤甸潰澶辫触</h1><p>{str(e)}</p>")



