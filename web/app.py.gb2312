        # 瀹氫箟绠€鍗曠殑鏇夸唬鍑芥暟

        def load_toml_config(path):

            print(f"浣跨敤鍐呯疆鐨勯厤缃鍙栧姛锟? {path}")

            if not os.path.exists(path):

                return {}

            try:

                import toml

                with open(path, "r", encoding="utf-8") as f:

                    return toml.load(f)

            except:

                try:

                    import tomli

                    with open(path, "rb") as f:

                        return tomli.load(f)

                except:

                    return {}

        

        def save_toml_config(path, data):

            try:

                import toml

                with open(path, "w", encoding="utf-8") as f:

                    toml.dump(data, f)

                return True

            except:

                return False



