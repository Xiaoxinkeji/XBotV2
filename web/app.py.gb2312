# 妫€鏌ユ満鍣ㄤ汉鐘舵€佸彉鍖栧苟瑙﹀彂閫氱煡

def check_robot_status_change(robot_status):

    """妫€鏌ユ満鍣ㄤ汉鐘舵€佸彉鍖栧苟瑙﹀彂閫氱煡"""

    global _last_robot_status

    current_is_online = robot_status.get("is_online", False)

    last_is_online = _last_robot_status.get("is_online", False)

    

    # 鑾峰彇閫氱煡閰嶇疆

    config = get_config()

    notification_config = config.get("Notification", {})

    enable_notification = notification_config.get("enable", False)

    pushplus_token = notification_config.get("pushplus-token", "")

    notify_online = notification_config.get("notify-online", True)

    notify_offline = notification_config.get("notify-offline", True)

    online_title = notification_config.get("online-title", "鏈哄櫒浜哄凡涓婄嚎")

    offline_title = notification_config.get("offline-title", "鏈哄櫒浜哄凡鎺夌嚎")

    

    # 鐘舵€佸彂鐢熷彉锟?

    if current_is_online != last_is_online:

        logger.info(f"鏈哄櫒浜虹姸鎬佸彉锟? {'涓婄嚎' if current_is_online else '绂荤嚎'}")

        

        # 濡傛灉鍚敤浜嗛€氱煡涓擯ushPlus浠ょ墝鏈夋晥

        if enable_notification and pushplus_token:

            # 鏋勫缓閫氱煡鍐呭

            if current_is_online and notify_online:

                # 鏈哄櫒浜轰笂绾块€氱煡

                system_info = get_system_info()

                user_info = robot_status.get("user_info", {})

                plugins = get_plugins()

                active_plugins = [p for p in plugins if p.get("enabled", False)]

                

                content = f"""

                ### 鏈嶅姟鍣ㄤ俊锟?

                - 绯荤粺: {system_info.get('os', 'Unknown')}

                - 杩愯鏃堕棿: {system_info.get('uptime', 'Unknown')}

                - CPU浣跨敤锟? {system_info.get('cpu_usage', 0)}%

                - 鍐呭瓨浣跨敤锟? {system_info.get('memory_usage', 0)}%

                

                ### 寰俊璐﹀彿

                - 鏄电О: {user_info.get('nickname', 'Unknown')}

                - 寰俊ID: {user_info.get('wxid', 'Unknown')}

                

                ### 宸叉縺娲绘彃锟?{len(active_plugins)})

                {', '.join([p.get('name', 'Unknown') for p in active_plugins])}

                """

                

                # 鍙戦€佷笂绾块€氱煡

                try:

                    send_notification(online_title, content)

                    logger.info("宸插彂閫佹満鍣ㄤ汉涓婄嚎閫氱煡")

                except Exception as e:

                    logger.error(f"鍙戦€佷笂绾块€氱煡澶辫触: {e}")

            

            elif not current_is_online and notify_offline:

                # 鏈哄櫒浜虹绾块€氱煡

                system_info = get_system_info()

                user_info = _last_robot_status.get("user_info", {})

                last_active_time = _last_robot_status.get("last_active_time", "鏈煡")

                

                content = f"""

                ### 鏈嶅姟鍣ㄤ俊锟?

                - 绯荤粺: {system_info.get('os', 'Unknown')}

                - 杩愯鏃堕棿: {system_info.get('uptime', 'Unknown')}

                

                ### 鏈€鍚庡湪绾夸俊锟?

                - 鏄电О: {user_info.get('nickname', 'Unknown')}

                - 寰俊ID: {user_info.get('wxid', 'Unknown')}

                - 鏈€鍚庢椿锟? {last_active_time}

                """

                

                # 鍙戦€佺绾块€氱煡

                try:

                    send_notification(offline_title, content)

                    logger.info("宸插彂閫佹満鍣ㄤ汉绂荤嚎閫氱煡")

                except Exception as e:

                    logger.error(f"鍙戦€佺绾块€氱煡澶辫触: {e}")

    

    # 鏇存柊涓婁竴娆＄姸锟?

    _last_robot_status = robot_status

    _last_robot_status["last_check_time"] = time.time()



# 鍙戦€侀€氱煡

def send_notification(title, content):

    """鍙戦€佹帹閫侀€氱煡"""

    config = get_config()

    notification_config = config.get("Notification", {})

    token = notification_config.get("pushplus-token", "")

    

    if not token:

        logger.warning("鏈厤缃甈ushPlus浠ょ墝锛屾棤娉曞彂閫侀€氱煡")

        return False

    

    try:

        import requests

        url = "http://www.pushplus.plus/send"

        data = {

            "token": token,

            "title": title,

            "content": content,

            "template": "markdown"

        }

        response = requests.post(url, json=data)

        result = response.json()

        

        if result.get("code") == 200:

            return True

        else:

            logger.warning(f"PushPlus閫氱煡鍙戦€佸け锟? {result.get('msg', '鏈煡閿欒')}")

            return False

    except Exception as e:

        logger.error(f"鍙戦€侀€氱煡鍑洪敊: {e}")

        return False



# 鑾峰彇娑堟伅缁熻

def get_message_stats():

    """鑾峰彇娑堟伅缁熻淇℃伅"""

    try:

        # 鍋囪鎴戜滑鏈変竴涓秷鎭暟鎹簱锛屼粠涓幏鍙栫粺璁′俊锟?

        # 杩欓噷绠€鍖栦负杩斿洖鍥哄畾缁撴瀯

        current_time = datetime.now()

        today = current_time.replace(hour=0, minute=0, second=0, microsecond=0)

        yesterday = today - timedelta(days=1)

        

        # 灏濊瘯浠庢暟鎹簱鑾峰彇娑堟伅缁熻

        try:

            # 杩欓儴鍒嗕唬鐮佸簲璇ユ牴鎹疄闄呯殑鏁版嵁搴撶粨鏋勬潵缂栧啓

            # 杩欓噷鍙槸涓€涓ず渚嬫锟?

            import sqlite3

            conn = sqlite3.connect(str(Path(BASE_DIR) / "database" / "message.db"))

            cursor = conn.cursor()

            

            # 鑾峰彇浠婃棩娑堟伅鏁伴噺

            cursor.execute("SELECT COUNT(*) FROM messages WHERE timestamp >= ?", (today.timestamp(),))

            today_count = cursor.fetchone()[0]

            

            # 鑾峰彇鏄ㄦ棩娑堟伅鏁伴噺

            cursor.execute("SELECT COUNT(*) FROM messages WHERE timestamp >= ? AND timestamp < ?", 

                          (yesterday.timestamp(), today.timestamp()))

            yesterday_count = cursor.fetchone()[0]

            

            # 鑾峰彇鎬绘秷鎭暟锟?

            cursor.execute("SELECT COUNT(*) FROM messages")

            total_count = cursor.fetchone()[0]

            

            # 鑾峰彇杩囧幓7澶╃殑娑堟伅鏁伴噺

            seven_days_ago = today - timedelta(days=7)

            cursor.execute("SELECT COUNT(*) FROM messages WHERE timestamp >= ?", (seven_days_ago.timestamp(),))

            week_count = cursor.fetchone()[0]

            

            conn.close()

            

            return {

                "today": today_count,

                "yesterday": yesterday_count,

                "total": total_count,

                "week": week_count,

                "last_updated": current_time.strftime("%Y-%m-%d %H:%M:%S")

            }

            

        except Exception as db_error:

            logger.warning(f"鏃犳硶浠庢暟鎹簱鑾峰彇娑堟伅缁熻: {db_error}")

            # 濡傛灉鏁版嵁搴撴煡璇㈠け璐ワ紝杩斿洖榛樿锟?

            return {

                "today": 0,

                "yesterday": 0,

                "total": 0,

                "week": 0,

                "last_updated": current_time.strftime("%Y-%m-%d %H:%M:%S"),

                "error": str(db_error)

            }

            

    except Exception as e:

        logger.error(f"鑾峰彇娑堟伅缁熻鏃跺嚭锟? {e}")

        return {

            "today": 0,

            "yesterday": 0,

            "total": 0,

            "week": 0,

            "error": str(e)

        }



# 纭繚蹇呰鐨勭洰褰曞瓨锟?

def ensure_directories():

    """纭繚蹇呰鐨勭洰褰曠粨鏋勫瓨锟?""

    logger.info("寮€濮嬫鏌ュ苟鍒涘缓蹇呰鐨勭洰褰曠粨锟?..")

    dirs = [

        PROJECT_ROOT / "logs",

        PROJECT_ROOT / "resource",

        PROJECT_ROOT / "resource" / "images",  # 娣诲姞鍥剧墖璧勬簮鐩綍

        PROJECT_ROOT / "resource" / "qrcode",  # 娣诲姞浜岀淮鐮佺洰锟?

        PROJECT_ROOT / "database",

        PROJECT_ROOT / "plugins",

        PROJECT_ROOT / "web" / "templates",

        PROJECT_ROOT / "web" / "static",

        PROJECT_ROOT / "web" / "static" / "css",

        PROJECT_ROOT / "web" / "static" / "js",

        PROJECT_ROOT / "web" / "static" / "img"

    ]

    

    created_count = 0

    for directory in dirs:

        if not directory.exists():

            logger.warning(f"鐩綍涓嶅瓨鍦紝灏濊瘯鍒涘缓: {directory}")

            try:

                directory.mkdir(parents=True, exist_ok=True)

                logger.info(f"鎴愬姛鍒涘缓鐩綍: {directory}")

                created_count += 1

            except Exception as e:

                logger.error(f"鍒涘缓鐩綍澶辫触 {directory}: {e}")

                logger.error(traceback.format_exc())

                

    if created_count > 0:

        logger.info(f"鍏卞垱寤轰簡 {created_count} 涓洰锟?)

    else:

        logger.info("鎵€鏈夊繀瑕佺殑鐩綍宸茬粡瀛樺湪")

    

    # 纭繚templates鐩綍涓湁蹇呰鐨勬ā鏉挎枃锟?

    template_dir = PROJECT_ROOT / "web" / "templates"

    if not list(template_dir.glob("*.html")):

        logger.warning("templates鐩綍涓虹┖锛屽彲鑳戒細瀵艰嚧Web鐣岄潰鏃犳硶姝ｅ父鏄剧ず")

    

    # 纭繚static鐩綍涓湁蹇呰鐨勯潤鎬佹枃锟?

    static_dir = PROJECT_ROOT / "web" / "static"

    css_dir = static_dir / "css"

    js_dir = static_dir / "js"

    if not list(css_dir.glob("*.css")) or not list(js_dir.glob("*.js")):

        logger.warning("闈欐€佹枃浠剁洰褰曞彲鑳界己灏戝繀瑕佺殑CSS鎴朖S鏂囦欢锛屽彲鑳戒細褰卞搷Web鐣岄潰鐨勬樉绀哄拰鍔熻兘")

    

    # 妫€鏌esource鐩綍涓殑鍏抽敭鏂囦欢

    resource_dir = PROJECT_ROOT / "resource"

    if not (resource_dir / "robot_stat.json").exists():

        try:

            # 鍒涘缓涓€涓熀鏈殑鐘舵€佹枃锟?

            with open(resource_dir / "robot_stat.json", "w", encoding="utf-8") as f:

                json.dump({"status": "offline", "last_update": int(time.time())}, f)

            logger.info("鍒涘缓浜嗛粯璁ょ殑robot_stat.json鏂囦欢")

        except Exception as e:

            logger.error(f"鍒涘缓robot_stat.json澶辫触: {e}")

            

    return True



# 璁剧疆宸ヤ綔鐩綍

ensure_directories()



