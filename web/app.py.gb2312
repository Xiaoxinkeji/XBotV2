@app.get("/api/messages")

async def get_messages_api(

    page: int = 1, 

    limit: int = 10, 

    search: str = None, 

    username: str = Depends(get_current_username)

):

    """鑾峰彇娑堟伅鍒楄〃API鎺ュ彛"""

    try:

        # 鑾峰彇娑堟伅鏁版嵁

        # 涓存椂妯℃嫙鏁版嵁锛岀敤浜庡墠绔祴锟?

        mock_messages = [

            {

                "id": "1",

                "sender": "寮犱笁 (wxid_123456)",

                "content": "浣犲ソ锛岃繖鏄竴鏉℃祴璇曟秷锟?,

                "type": "text",

                "timestamp": int(time.time() - 3600 * 5) * 1000  # 5灏忔椂锟?

            },

            {

                "id": "2",

                "sender": "鏉庡洓 (wxid_234567)",

                "content": "https://example.com/image.jpg",

                "type": "image",

                "timestamp": int(time.time() - 3600 * 3) * 1000  # 3灏忔椂锟?

            },

            {

                "id": "3",

                "sender": "娴嬭瘯锟?(23456789@chatroom)",

                "content": "杩欐槸鏉ヨ嚜缇よ亰鐨勬秷锟?,

                "type": "text",

                "timestamp": int(time.time() - 3600 * 1) * 1000  # 1灏忔椂锟?

            },

            {

                "id": "4",

                "sender": "绯荤粺閫氱煡",

                "content": "鏈哄櫒浜哄凡鎴愬姛鐧诲綍",

                "type": "system",

                "timestamp": int(time.time() - 600) * 1000  # 10鍒嗛挓锟?

            },

            {

                "id": "5",

                "sender": "鐜嬩簲 (wxid_345678)",

                "content": "https://example.com/voice.mp3",

                "type": "voice",

                "timestamp": int(time.time() - 300) * 1000  # 5鍒嗛挓锟?

            }

        ]

        

        # 濡傛灉鏈夋悳绱㈠弬鏁帮紝杩囨护娑堟伅

        if search:

            search = search.lower()

            mock_messages = [

                msg for msg in mock_messages 

                if search in msg["sender"].lower() or search in msg["content"].lower()

            ]

        

        # 鍒嗛〉淇℃伅

        total_messages = len(mock_messages)

        total_pages = max(1, math.ceil(total_messages / limit))

        current_page = min(page, total_pages)

        

        # 璁＄畻褰撳墠椤电殑娑堟伅

        start_idx = (current_page - 1) * limit

        end_idx = start_idx + limit

        page_messages = mock_messages[start_idx:end_idx]

        

        return {

            "messages": page_messages,

            "total": total_messages,

            "page": page,

            "limit": limit,

            "pages": total_pages

        }

    except Exception as e:

        logger.error(f"鑾峰彇娑堟伅澶辫触: {e}")

        logger.error(traceback.format_exc())

    return await logout(request)



if __name__ == "__main__":

    start_web_server() 



