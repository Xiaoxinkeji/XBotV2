# 创建vendor目录
mkdir -p web_ui/static/vendor

# 安装curl(如果容器中没有)
apt-get update && apt-get install -y curl

# 下载Vue.js
curl -o web_ui/static/vendor/vue.global.min.js https://unpkg.com/vue@3.3.4/dist/vue.global.prod.js

# 下载Element Plus
curl -o web_ui/static/vendor/element-plus.full.min.js https://unpkg.com/element-plus@2.3.14/dist/index.full.min.js
curl -o web_ui/static/vendor/element-plus.min.css https://unpkg.com/element-plus@2.3.14/dist/index.min.css

# 下载Axios
curl -o web_ui/static/vendor/axios.min.js https://unpkg.com/axios@1.4.0/dist/axios.min.js

# 下载ECharts
curl -o web_ui/static/vendor/echarts.min.js https://unpkg.com/echarts@5.4.2/dist/echarts.min.js 